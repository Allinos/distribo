<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Activate — ERP System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body class="auth-body">
<div class="auth-container">
  <div class="auth-card activation-card">
    <div class="auth-logo">
      <div class="auth-logo-icon">
        <i class="bi bi-shield-lock-fill"></i>
      </div>
      <h1 class="auth-title">Software Activation</h1>
      <p class="auth-subtitle">Enter your license details to activate the application</p>
    </div>

    <% if (expired) { %>
      <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Your license has expired. Please re-activate with a valid key.
      </div>
    <% } %>

    <% if (activation && activation.isActive) { %>
      <div class="alert alert-success">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Already Activated</strong><br>
        <small>App ID: <%= activation.applicationId %> | Expires: <%= activation.expiresAt ? new Date(activation.expiresAt).toLocaleDateString() : 'Never' %></small>
      </div>
      <a href="/auth/login" class="btn btn-primary w-100">
        <i class="bi bi-arrow-right-circle me-2"></i>Go to Login
      </a>
    <% } else { %>

    <div id="activationMsg" class="d-none mb-3"></div>

    <form id="activationForm">
      <div class="mb-3">
        <label class="form-label fw-medium">Application ID</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-fingerprint"></i></span>
          <input type="text" class="form-control" id="applicationId" name="applicationId"
            placeholder="e.g. ERP-2024-DEMO" required
            value="<%= process.env.APPLICATION_ID || '' %>">
        </div>
        <div class="form-text">Your unique application identifier provided during purchase.</div>
      </div>

      <div class="mb-4">
        <label class="form-label fw-medium">License Key</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
          <input type="text" class="form-control font-mono" id="licenseKey" name="licenseKey"
            placeholder="XXXX-XXXX-XXXX-XXXX or DEMO-LICENSE-KEY" required>
          <button class="btn btn-outline-secondary" type="button" id="toggleKey">
            <i class="bi bi-eye"></i>
          </button>
        </div>
        <div class="form-text">Use <strong>DEMO-LICENSE-KEY</strong> for demo activation.</div>
      </div>

      <button type="submit" class="btn btn-primary w-100 btn-lg" id="activateBtn">
        <span class="btn-text"><i class="bi bi-shield-check me-2"></i>Activate Now</span>
        <span class="btn-loader d-none">
          <span class="spinner-border spinner-border-sm me-2"></span>Verifying...
        </span>
      </button>
    </form>

    <div class="text-center mt-4">
      <small class="text-muted">
        <i class="bi bi-lock me-1"></i>
        Your license is verified securely. Internet connection may be required.
      </small>
    </div>

    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.getElementById('activationForm')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('activateBtn');
  const msg = document.getElementById('activationMsg');
  const appId = document.getElementById('applicationId').value.trim();
  const licKey = document.getElementById('licenseKey').value.trim();

  btn.querySelector('.btn-text').classList.add('d-none');
  btn.querySelector('.btn-loader').classList.remove('d-none');
  btn.disabled = true;
  msg.className = 'd-none';

  try {
    const res = await fetch('/activation/activate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ applicationId: appId, licenseKey: licKey })
    });
    const data = await res.json();

    msg.className = `alert ${data.success ? 'alert-success' : 'alert-danger'}`;
    msg.innerHTML = `<i class="bi bi-${data.success ? 'check-circle' : 'x-circle'}-fill me-2"></i>${data.message}`;
    msg.classList.remove('d-none');

    if (data.success) {
      setTimeout(() => { window.location.href = '/auth/login'; }, 1500);
    }
  } catch (err) {
    msg.className = 'alert alert-danger';
    msg.innerHTML = '<i class="bi bi-x-circle-fill me-2"></i>Network error. Please try again.';
    msg.classList.remove('d-none');
  } finally {
    btn.querySelector('.btn-text').classList.remove('d-none');
    btn.querySelector('.btn-loader').classList.add('d-none');
    btn.disabled = false;
  }
});

// Toggle key visibility
document.getElementById('toggleKey')?.addEventListener('click', function() {
  const inp = document.getElementById('licenseKey');
  const icon = this.querySelector('i');
  if (inp.type === 'password') {
    inp.type = 'text';
    icon.className = 'bi bi-eye-slash';
  } else {
    inp.type = 'password';
    icon.className = 'bi bi-eye';
  }
});
</script>
</body>
</html>
