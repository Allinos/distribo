<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Database Setup — ERP System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body class="auth-body">
<div class="auth-container" style="max-width:560px">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="auth-logo-icon"><i class="bi bi-database-fill-gear"></i></div>
      <h1 class="auth-title">Database Setup</h1>
      <p class="auth-subtitle">Configure your MySQL database connection</p>
    </div>

    <%/* Show current config banner if already saved */%>
    <% if (typeof saved !== 'undefined' && saved) { %>
    <div class="alert alert-success mb-3">
      <i class="bi bi-check-circle-fill me-2"></i>
      <strong>Database already configured:</strong>
      <%= saved.host || 'Cloud DB' %><% if (saved.database) { %> / <%= saved.database %><% } %>
      <a href="#" onclick="document.getElementById('resetForm').submit()" class="float-end text-danger small">
        <i class="bi bi-x-circle me-1"></i>Reset
      </a>
    </div>
    <form id="resetForm" action="/db-setup/reset" method="POST" class="d-none"></form>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
    <% } %>

    <!-- DB Type Tabs -->
    <ul class="nav nav-pills nav-fill mb-4">
      <li class="nav-item">
        <button class="nav-link <%= (typeof dbType === 'undefined' || dbType === 'local') ? 'active' : '' %>" id="localTab" onclick="switchTab('local')">
          <i class="bi bi-hdd me-2"></i>Local MySQL
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link <%= (typeof dbType !== 'undefined' && dbType === 'cloud') ? 'active' : '' %>" id="cloudTab" onclick="switchTab('cloud')">
          <i class="bi bi-cloud me-2"></i>Cloud / Remote
        </button>
      </li>
    </ul>

    <div id="alertBox" class="d-none mb-3"></div>

    <!-- Local DB Form -->
    <div id="localForm" class="<%= (typeof dbType !== 'undefined' && dbType === 'cloud') ? 'd-none' : '' %>">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label fw-medium">MySQL Host <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="lHost"
            value="<%= (typeof saved !== 'undefined' && saved && saved.host) ? saved.host : 'localhost' %>"
            placeholder="localhost">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-medium">Port</label>
          <input type="number" class="form-control" id="lPort"
            value="<%= (typeof saved !== 'undefined' && saved && saved.port) ? saved.port : '3306' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-medium">Username <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="lUser"
            value="<%= (typeof saved !== 'undefined' && saved && saved.user) ? saved.user : 'root' %>"
            placeholder="root">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-medium">Password</label>
          <input type="password" class="form-control" id="lPassword" placeholder="Leave blank if none">
        </div>
        <div class="col-12">
          <label class="form-label fw-medium">Database Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control font-mono" id="lDatabase"
            value="<%= (typeof saved !== 'undefined' && saved && saved.database) ? saved.database : 'erp_db' %>"
            placeholder="erp_db">
          <div class="form-text">The database will be created automatically if it doesn't exist.</div>
        </div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button class="btn btn-outline-secondary" type="button" onclick="testLocalConnection()">
          <i class="bi bi-lightning me-2"></i>Test Connection
        </button>
        <button class="btn btn-primary flex-fill" type="button" onclick="setupLocal()">
          <span class="btn-text"><i class="bi bi-database-fill-add me-2"></i>Setup Database</span>
          <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Setting up...</span>
        </button>
      </div>
    </div>

    <!-- Cloud DB Form -->
    <div id="cloudForm" class="<%= (typeof dbType !== 'undefined' && dbType === 'cloud') ? '' : 'd-none' %>">
      <div class="mb-3">
        <label class="form-label fw-medium">Database URL <span class="text-danger">*</span></label>
        <input type="text" class="form-control font-mono" id="cDbUrl"
          placeholder="mysql://user:password@host:3306/database">
        <div class="form-text">Full MySQL connection URL (PlanetScale, Railway, AWS RDS, etc.)</div>
      </div>
      <button class="btn btn-primary w-100" type="button" onclick="setupCloud()">
        <span class="btn-text"><i class="bi bi-cloud-upload me-2"></i>Connect Cloud Database</span>
        <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Connecting...</span>
      </button>
    </div>

    <div class="mt-4 pt-3 border-top">
      <div class="d-flex align-items-center gap-2 text-muted small">
        <i class="bi bi-shield-lock flex-shrink-0"></i>
        <span>Credentials are encrypted with AES-256 and stored locally on this device only.</span>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
function switchTab(type) {
  document.getElementById('localForm').classList.toggle('d-none', type !== 'local');
  document.getElementById('cloudForm').classList.toggle('d-none', type !== 'cloud');
  document.getElementById('localTab').classList.toggle('active', type === 'local');
  document.getElementById('cloudTab').classList.toggle('active', type === 'cloud');
  hideAlert();
}

function showAlert(type, msg) {
  const el = document.getElementById('alertBox');
  el.className = 'alert alert-' + type;
  el.innerHTML = '<i class="bi bi-' + (type === 'success' ? 'check-circle' : 'exclamation-triangle') + '-fill me-2"></i>' + msg;
  el.classList.remove('d-none');
}

function hideAlert() {
  document.getElementById('alertBox').classList.add('d-none');
}

function setLoading(btn, loading) {
  btn.querySelector('.btn-text').classList.toggle('d-none', loading);
  btn.querySelector('.btn-loader').classList.toggle('d-none', !loading);
  btn.disabled = loading;
}

async function testLocalConnection() {
  const btn = event.currentTarget;
  const origHtml = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Testing...';
  btn.disabled = true;
  hideAlert();
  try {
    const res = await fetch('/db-setup/test-connection', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        host: document.getElementById('lHost').value,
        port: document.getElementById('lPort').value,
        user: document.getElementById('lUser').value,
        password: document.getElementById('lPassword').value,
        database: document.getElementById('lDatabase').value
      })
    });
    const data = await res.json();
    showAlert(data.success ? 'success' : 'danger',
      data.success ? '✓ Connection successful! Database is reachable.' : 'Connection failed: ' + data.message);
  } catch (e) {
    showAlert('danger', 'Network error. Is the server running?');
  } finally {
    btn.innerHTML = origHtml;
    btn.disabled = false;
  }
}

async function setupLocal() {
  const btn = document.querySelector('#localForm .btn-primary');
  setLoading(btn, true);
  hideAlert();
  try {
    const res = await fetch('/db-setup/setup-local', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        host: document.getElementById('lHost').value,
        port: document.getElementById('lPort').value,
        user: document.getElementById('lUser').value,
        password: document.getElementById('lPassword').value,
        database: document.getElementById('lDatabase').value
      })
    });
    const data = await res.json();
    if (data.success) {
      showAlert('success', data.message + ' Redirecting to login...');
      setTimeout(() => window.location.href = '/auth/login', 2000);
    } else {
      showAlert('danger', data.message);
      setLoading(btn, false);
    }
  } catch (e) {
    showAlert('danger', 'Network error. Is the server running?');
    setLoading(btn, false);
  }
}

async function setupCloud() {
  const btn = document.querySelector('#cloudForm .btn-primary');
  setLoading(btn, true);
  hideAlert();
  try {
    const res = await fetch('/db-setup/setup-cloud', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ dbUrl: document.getElementById('cDbUrl').value })
    });
    const data = await res.json();
    if (data.success) {
      showAlert('success', data.message + ' Redirecting to login...');
      setTimeout(() => window.location.href = '/auth/login', 2000);
    } else {
      showAlert('danger', data.message);
      setLoading(btn, false);
    }
  } catch (e) {
    showAlert('danger', 'Network error.');
    setLoading(btn, false);
  }
}
</script>
</body>
</html>
