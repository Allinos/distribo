<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title">New Invoice</h2>
      <p class="page-subtitle">Invoice # <strong><%= invoiceNo %></strong></p>
    </div>
    <div class="page-actions">
      <a href="/sales" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back
      </a>
    </div>
  </div>

  <div id="invoiceAlert" class="d-none mb-3"></div>

  <div class="row g-4">
    <!-- Left: Invoice Builder -->
    <div class="col-xl-8">
      <div class="card erp-card">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-list-ul me-2"></i>Invoice Items</h5>
        </div>
        <div class="card-body">
          <!-- Product Search -->
          <div class="row g-3 mb-3">
            <div class="col-md-8">
              <label class="form-label small fw-medium">Search & Add Product</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" id="productSearch" placeholder="Type product name or SKU...">
                <button class="btn btn-outline-secondary" type="button" id="clearSearch">
                  <i class="bi bi-x"></i>
                </button>
              </div>
              <div id="productDropdown" class="product-dropdown d-none"></div>
            </div>
          </div>

          <!-- Items Table -->
          <div class="table-responsive">
            <table class="table erp-table" id="invoiceTable">
              <thead>
                <tr>
                  <th>Product</th>
                  <th style="width:100px">Qty</th>
                  <th style="width:120px">Price (₹)</th>
                  <th style="width:80px">Tax %</th>
                  <th style="width:130px">Total</th>
                  <th style="width:50px"></th>
                </tr>
              </thead>
              <tbody id="invoiceItems">
                <tr id="emptyRow">
                  <td colspan="6" class="text-center py-4 text-muted">
                    <i class="bi bi-cart-plus fs-3 d-block mb-2"></i>
                    Search and add products above
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Invoice Summary -->
    <div class="col-xl-4">
      <div class="card erp-card mb-4">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-person me-2"></i>Customer & Details</h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label small fw-medium">Warehouse</label>
            <select class="form-select" id="warehouseId" onchange="onWarehouseChange()">
              <option value="">— No specific warehouse —</option>
              <% if (typeof warehouses !== 'undefined') { warehouses.forEach(w => { %>
                <option value="<%= w.id %>" <%= (typeof defaultWarehouseId !== 'undefined' && defaultWarehouseId === w.id) ? 'selected' : '' %>>
                  <%= w.name %><% if (w.isDefault) { %> ★<% } %>
                </option>
              <% }) } %>
            </select>
            <div class="form-text">Select warehouse to check per-warehouse stock</div>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Customer (Optional)</label>
            <select class="form-select" id="customerId">
              <option value="">Walk-in Customer</option>
              <% customers.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.name %> <%= c.phone ? `(${c.phone})` : '' %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Payment Mode</label>
            <select class="form-select" id="paymentMode">
              <option value="CASH">💵 Cash</option>
              <option value="CARD">💳 Card</option>
              <option value="UPI">📱 UPI</option>
              <option value="BANK_TRANSFER">🏦 Bank Transfer</option>
              <option value="CREDIT">📋 Credit</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Notes</label>
            <textarea class="form-control" id="invoiceNotes" rows="2" placeholder="Optional notes..."></textarea>
          </div>
        </div>
      </div>

      <!-- Totals Card -->
      <div class="card erp-card">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-calculator me-2"></i>Summary</h5>
        </div>
        <div class="card-body">
          <div class="invoice-summary">
            <div class="summary-row">
              <span>Subtotal</span>
              <span id="sumSubtotal">₹0.00</span>
            </div>
            <div class="summary-row">
              <span>Tax</span>
              <span id="sumTax">₹0.00</span>
            </div>
            <div class="summary-row">
              <span>Discount (₹)</span>
              <input type="number" class="form-control form-control-sm w-50 text-end"
                id="discountInput" value="0" min="0" step="0.01" oninput="calcTotals()">
            </div>
            <hr>
            <div class="summary-row summary-total">
              <span>Total</span>
              <span id="sumTotal">₹0.00</span>
            </div>
          </div>

          <div class="d-grid gap-2 mt-3">
            <button class="btn btn-success btn-lg" id="saveInvoiceBtn" onclick="saveInvoice()">
              <span class="btn-text"><i class="bi bi-check-circle me-2"></i>Save Invoice</span>
              <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Saving...</span>
            </button>
            <button class="btn btn-outline-secondary" onclick="resetInvoice()">
              <i class="bi bi-arrow-counterclockwise me-2"></i>Reset
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const INVOICE_NO = '<%= invoiceNo %>';
let invoiceItems = [];
let searchTimeout;

// Warehouse change
function onWarehouseChange() {
  // Clear items when warehouse changes
  if (invoiceItems.length > 0) {
    if (!confirm('Changing warehouse will clear current items. Continue?')) {
      document.getElementById('warehouseId').value = '';
      return;
    }
    invoiceItems = [];
    renderItems();
    calcTotals();
  }
}

// Product search
document.getElementById('productSearch').addEventListener('input', function() {
  clearTimeout(searchTimeout);
  const q = this.value.trim();
  if (q.length < 2) {
    document.getElementById('productDropdown').classList.add('d-none');
    return;
  }
  searchTimeout = setTimeout(() => fetchProducts(q), 300);
});

document.getElementById('clearSearch').addEventListener('click', function() {
  document.getElementById('productSearch').value = '';
  document.getElementById('productDropdown').classList.add('d-none');
});

async function fetchProducts(query) {
  try {
    const warehouseId = document.getElementById('warehouseId').value;
    const url = warehouseId
      ? `/warehouses/api/${warehouseId}/stock?search=${encodeURIComponent(query)}`
      : `/products/api/list?search=${encodeURIComponent(query)}`;
    const res = await fetch(url);
    const products = await res.json();
    const dd = document.getElementById('productDropdown');
    if (!products.length) {
      dd.innerHTML = '<div class="dropdown-item text-muted">No products found</div>';
    } else {
      dd.innerHTML = products.map(p => `
        <div class="dropdown-item product-item" onclick='addProduct(${JSON.stringify(p)})'>
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="fw-medium">${p.name}</div>
              <small class="text-muted">${p.sku} · Stock: ${p.stock} ${p.unit}</small>
            </div>
            <div class="text-end">
              <div class="fw-semibold text-primary">₹${parseFloat(p.price).toLocaleString('en-IN')}</div>
              <small class="text-muted">${p.tax}% tax</small>
            </div>
          </div>
        </div>
      `).join('');
    }
    dd.classList.remove('d-none');
  } catch (e) {
    console.error(e);
  }
}

function addProduct(product) {
  document.getElementById('productDropdown').classList.add('d-none');
  document.getElementById('productSearch').value = '';

  // Check if already in list
  const existing = invoiceItems.find(i => i.productId === product.id);
  if (existing) {
    existing.qty++;
    renderItems();
    calcTotals();
    return;
  }

  invoiceItems.push({
    productId: product.id,
    name: product.name,
    sku: product.sku,
    price: parseFloat(product.price),
    tax: parseFloat(product.tax),
    qty: 1,
    maxStock: product.stock
  });

  renderItems();
  calcTotals();
}

function renderItems() {
  const tbody = document.getElementById('invoiceItems');
  const emptyRow = document.getElementById('emptyRow');
  if (emptyRow) emptyRow.remove();

  if (invoiceItems.length === 0) {
    tbody.innerHTML = `<tr id="emptyRow">
      <td colspan="6" class="text-center py-4 text-muted">
        <i class="bi bi-cart-plus fs-3 d-block mb-2"></i>Search and add products above
      </td>
    </tr>`;
    return;
  }

  tbody.innerHTML = invoiceItems.map((item, idx) => {
    // Ensure we aren't working with NaN
    const price = parseFloat(item.price) || 0;
    const qty = parseInt(item.qty) || 0;
    const tax = parseFloat(item.tax) || 0;
    
    const lineTotal = price * qty * (1 + tax / 100);

    return `
      <tr>
        <td>
          <div class="fw-medium">${item.name}</div>
          <small class="text-muted">${item.sku}</small>
        </td>
        <td>
          <input type="number" class="form-control form-control-sm" 
            value="${qty}" min="1"
            max="${item.maxStock || 99999}" 
            onchange="updateQty(${idx}, this.value)" style="width:75px">
        </td>
        <td>
          <input type="number" class="form-control form-control-sm" 
            value="${price.toFixed(2)}" min="0" step="0.01"
            onchange="updatePrice(${idx}, this.value)" style="width:100px">
        </td>
        <td class="text-muted">${tax}%</td>
        <td class="fw-semibold">₹${lineTotal.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
        <td>
          <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeItem(${idx})">
            <i class="bi bi-trash"></i>
          </button>
        </td>
      </tr>
    `;
  }).join('');
}
function updateQty(idx, val) {
  let num = parseInt(val);
  if (isNaN(num) || num < 1) num = 1;
  
  // Cap at max stock if it exists
  const max = invoiceItems[idx].maxStock;
  if (max !== undefined && num > max) num = max;

  invoiceItems[idx].qty = num;
  renderItems();
  calcTotals();
}

function updatePrice(idx, val) {
  let num = parseFloat(val);
  if (isNaN(num)) num = 0;
  
  invoiceItems[idx].price = num;
  renderItems();
  calcTotals();
}
function removeItem(idx) {
  invoiceItems.splice(idx, 1);
  renderItems();
  calcTotals();
}

function calcTotals() {
  let subtotal = 0, taxAmt = 0;
  invoiceItems.forEach(item => {
    const base = item.price * item.qty;
    const tax = (base * item.tax) / 100;
    subtotal += base;
    taxAmt += tax;
  });
  const discount = parseFloat(document.getElementById('discountInput').value) || 0;
  const total = subtotal + taxAmt - discount;

  document.getElementById('sumSubtotal').textContent = `₹${subtotal.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2})}`;
  document.getElementById('sumTax').textContent = `₹${taxAmt.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2})}`;
  document.getElementById('sumTotal').textContent = `₹${total.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2})}`;
}

async function saveInvoice() {
  if (invoiceItems.length === 0) {
    showAlert('danger', 'Please add at least one product.');
    return;
  }

  const btn = document.getElementById('saveInvoiceBtn');
  btn.querySelector('.btn-text').classList.add('d-none');
  btn.querySelector('.btn-loader').classList.remove('d-none');
  btn.disabled = true;

  const payload = {
    invoiceNo: INVOICE_NO,
    customerId: document.getElementById('customerId').value || null,
    paymentMode: document.getElementById('paymentMode').value,
    discount: document.getElementById('discountInput').value,
    notes: document.getElementById('invoiceNotes').value,
    warehouseId: document.getElementById('warehouseId').value,
    items: invoiceItems.map(i => ({
      productId: i.productId,
      quantity: i.qty,
      price: i.price,
      tax: i.tax
    }))
  };

  try {
    const res = await fetch('/sales', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showAlert('success', data.message);
      setTimeout(() => { window.location.href = `/sales/${data.saleId}`; }, 1000);
    } else {
      showAlert('danger', data.message);
      btn.querySelector('.btn-text').classList.remove('d-none');
      btn.querySelector('.btn-loader').classList.add('d-none');
      btn.disabled = false;
    }
  } catch (err) {
    showAlert('danger', 'Network error. Please try again.');
    btn.querySelector('.btn-text').classList.remove('d-none');
    btn.querySelector('.btn-loader').classList.add('d-none');
    btn.disabled = false;
  }
}

function resetInvoice() {
  if (invoiceItems.length > 0 && !confirm('Clear all items?')) return;
  invoiceItems = [];
  renderItems();
  calcTotals();
  document.getElementById('discountInput').value = 0;
  document.getElementById('invoiceNotes').value = '';
}

function showAlert(type, msg) {
  const el = document.getElementById('invoiceAlert');
  el.className = `alert alert-${type}`;
  el.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'}-fill me-2"></i>${msg}`;
  el.classList.remove('d-none');
  el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Close dropdown on outside click
document.addEventListener('click', e => {
  if (!e.target.closest('#productSearch') && !e.target.closest('#productDropdown')) {
    document.getElementById('productDropdown').classList.add('d-none');
  }
});
</script>
