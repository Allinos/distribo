<div class="page-content py-4">
  <div class="page-header mb-4 d-flex justify-content-between align-items-center">
    <div>
      <h2 class="page-title h3 mb-1"><i class="bi bi-gear-fill me-2 text-primary"></i>Settings</h2>
      <p class="page-subtitle text-muted mb-0">Company profile, preferences and system configuration</p>
    </div>
  </div>

  <form action="/settings" method="POST">
    <input type="hidden" name="_method" value="PUT">

    <div class="row g-4">
      <div class="col-xl-7 col-lg-8">
        <div class="d-flex flex-column gap-4">
          
          <div class="card erp-card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom py-3">
              <h5 class="card-title mb-0"><i class="bi bi-building me-2 text-secondary"></i>Company Information</h5>
            </div>
            <div class="card-body p-4">
              <div class="row g-3">
                <div class="col-12 mb-2">
                  <label class="form-label fw-bold small text-uppercase text-muted">Company Name</label>
                  <input type="text" class="form-control form-control-lg" name="company_name" value="<%= settings.company_name || '' %>" placeholder="My Business">
                </div>
                <div class="col-12 mb-2">
                  <label class="form-label fw-bold small text-uppercase text-muted">Address</label>
                  <textarea class="form-control" name="company_address" rows="2" placeholder="Street, City, Zip..."><%= settings.company_address || '' %></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold small text-uppercase text-muted">Phone</label>
                  <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                    <input type="text" class="form-control" name="company_phone" value="<%= settings.company_phone || '' %>">
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold small text-uppercase text-muted">Email</label>
                  <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                    <input type="email" class="form-control" name="company_email" value="<%= settings.company_email || '' %>">
                  </div>
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold small text-uppercase text-muted">GSTIN</label>
                  <input type="text" class="form-control font-monospace" name="gstin" value="<%= settings.gstin || '' %>" placeholder="22AAAAA0000A1Z5">
                </div>
              </div>
            </div>
          </div>

          <div class="card erp-card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom py-3">
              <h5 class="card-title mb-0"><i class="bi bi-receipt me-2 text-secondary"></i>Invoice & Sales</h5>
            </div>
            <div class="card-body p-4">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold small text-uppercase text-muted">Currency Symbol</label>
                  <input type="text" class="form-control" name="currency" value="<%= settings.currency || '₹' %>" maxlength="5">
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold small text-uppercase text-muted">Invoice Prefix</label>
                  <input type="text" class="form-control" name="invoice_prefix" value="<%= settings.invoice_prefix || 'INV' %>" maxlength="10">
                  <div class="form-text mt-1 small">e.g. INV → INV-2024-0001</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold small text-uppercase text-muted">Tax Rate (%)</label>
                  <div class="input-group">
                    <input type="number" class="form-control" name="tax_rate" value="<%= settings.tax_rate || '18' %>" min="0" max="100" step="0.1">
                    <span class="input-group-text">%</span>
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold small text-uppercase text-muted">Low Stock Alert (units)</label>
                  <input type="number" class="form-control" name="low_stock_alert" value="<%= settings.low_stock_alert || '5' %>" min="0">
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold small text-uppercase text-muted">Expiry Alert (days)</label>
                  <input type="number" class="form-control" name="expiry_alert_days" value="<%= settings.expiry_alert_days || '60' %>" min="1">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold small text-uppercase text-muted">Invoice Footer Note</label>
                  <input type="text" class="form-control" name="footer_note" value="<%= settings.footer_note || '' %>" placeholder="Thank you for your business!">
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-5 col-lg-4">
        <div class="d-flex flex-column gap-4">
          
          <div class="card erp-card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-transparent border-bottom py-3">
              <h5 class="card-title mb-0"><i class="bi bi-shield-lock me-2 text-secondary"></i>System License</h5>
            </div>
            <div class="card-body p-4">
              <div class="mb-3 p-3 bg-light rounded-3 d-flex align-items-center">
                <div class="me-3 text-success fs-2">
                  <i class="bi bi-check-circle-fill"></i>
                </div>
                <div>
                  <div class="fw-bold">Application Activated</div>
                  <small class="text-muted">Software is currently active and licensed.</small>
                </div>
              </div>
              <form action="/activation/deactivate" method="POST" onsubmit="return confirm('Deactivate? You will need to re-activate to use the app.')">
                <button type="submit" class="btn btn-outline-danger btn-sm w-100 py-2">
                  <i class="bi bi-power me-2"></i>Deactivate License
                </button>
              </form>
            </div>
          </div>

          <div class="card erp-card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-transparent border-bottom py-3">
              <h5 class="card-title mb-0"><i class="bi bi-database me-2 text-secondary"></i>Data Backup</h5>
            </div>
            <div class="card-body p-4">
              <div class="p-3 bg-light rounded-3 mb-3 cursor-pointer border border-transparent hover-border-primary" onclick="location.href='/backup'" style="cursor: pointer;">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <i class="bi bi-cloud-check-fill text-success fs-5"></i>
                  <span class="fw-semibold">Ready to Backup</span>
                </div>
                <p class="small text-muted mb-3">Keep your data safe by creating a manual restoration point.</p>
                <button type="button" class="btn btn-primary btn-sm w-100 py-2">
                  <i class="bi bi-download me-2"></i>Create Manual Backup
                </button> 
              </div>
            </div>
          </div>

          <div class="card erp-card border-0 shadow-sm border-top border-primary border-4">
            <div class="card-header bg-light py-3">
              <h5 class="card-title mb-0 text-primary small fw-bold text-uppercase">Automatic Cloud Sync</h5>
            </div>
            <div class="card-body p-4">
              <div class="mb-4">
                <div class="form-check form-switch custom-switch mb-2">
                  <input class="form-check-input" type="checkbox" id="autoBackupToggle"
                    name="auto_backup_enabled" value="true"
                    <%= settings.auto_backup_enabled === 'true' ? 'checked' : '' %>
                    onchange="toggleBackupFields(this.checked)" style="width:2.8rem;height:1.4rem">
                  <label class="form-check-label ms-2 fw-bold" for="autoBackupToggle" id="backupToggleLabel">
                    <%= settings.auto_backup_enabled === 'true' ? 'Enabled' : 'Disabled' %>
                  </label>
                </div>
                <span class="badge <%= settings.auto_backup_enabled === 'true' ? 'bg-success' : 'bg-secondary' %>" id="backupStatusBadge">
                  <i class="bi bi-<%= settings.auto_backup_enabled === 'true' ? 'check-circle' : 'pause-circle' %> me-1"></i>
                  <%= settings.auto_backup_enabled === 'true' ? 'Running' : 'Stopped' %>
                </span>
              </div>

              <div id="backupConfigFields" style="<%= settings.auto_backup_enabled !== 'true' ? 'opacity:.45;pointer-events:none' : '' %>">
                <div class="mb-3">
                  <label class="form-label small fw-bold">Interval</label>
                  <select class="form-select border-2" name="auto_backup_interval_hours">
                    <% [
                      { val: '6',  label: 'Every 6 hours' },
                      { val: '12', label: 'Every 12 hours' },
                      { val: '24', label: 'Daily (24h)' },
                      { val: '48', label: 'Every 2 days' },
                      { val: '168',label: 'Weekly' }
                    ].forEach(opt => { %>
                    <option value="<%= opt.val %>" <%= settings.auto_backup_interval_hours === opt.val ? 'selected' : '' %>><%= opt.label %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="mb-4">
                  <label class="form-label small fw-bold">Save Location</label>
                  <input type="text" class="form-control border-2" name="auto_backup_path"
                    value="<%= settings.auto_backup_path || '' %>"
                    placeholder="User default path">
                </div>

                <div class="p-3 bg-dark text-white rounded-3">
                  <div class="small fw-semibold mb-2"><i class="bi bi-info-circle me-2"></i>Cloud Information</div>
                  <div class="small opacity-75 mb-3">Products, customers, and all financial history are encrypted and backed up.</div>
                  <button type="button" class="btn btn-primary btn-sm w-100" onclick="runBackupNow()" id="backupNowBtn">
                    <span class="btn-text"><i class="bi bi-arrow-repeat me-2"></i>Force Sync Now</span>
                    <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Processing...</span>
                  </button>
                  <div id="backupNowMsg" class="d-none mt-2"></div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="col-12 mt-2">
        <div class="card border-0 shadow-lg bg-white p-3">
          <div class="d-flex justify-content-end align-items-center gap-3">
            <a href="/" class="btn btn-link text-decoration-none text-muted fw-semibold">Discard Changes</a>
            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
              <i class="bi bi-check2-circle me-2"></i>Apply All Settings
            </button>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<style>
  .erp-card { border-radius: 12px; transition: transform 0.2s; }
  .form-control, .form-select { padding: 0.6rem 0.75rem; border-color: #e2e8f0; }
  .form-control:focus, .form-select:focus { box-shadow: 0 0 0 4px rgba(66, 153, 225, 0.15); border-color: #4299e1; }
  .hover-border-primary:hover { border-color: #0d6efd !important; }
  .cursor-pointer { cursor: pointer; }
</style>

<script>
function toggleBackupFields(enabled) {
  const fields = document.getElementById('backupConfigFields');
  const label  = document.getElementById('backupToggleLabel');
  const badge  = document.getElementById('backupStatusBadge');
  fields.style.opacity       = enabled ? '1' : '.45';
  fields.style.pointerEvents  = enabled ? '' : 'none';
  label.textContent = enabled ? 'Enabled' : 'Disabled';
  badge.className   = `badge ${enabled ? 'bg-success' : 'bg-secondary'}`;
  badge.innerHTML   = `<i class="bi bi-${enabled ? 'check-circle' : 'pause-circle'} me-1"></i>${enabled ? 'Running' : 'Stopped'}`;
}

async function runBackupNow() {
  const btn = document.getElementById('backupNowBtn');
  btn.querySelector('.btn-text').classList.add('d-none');
  btn.querySelector('.btn-loader').classList.remove('d-none');
  btn.disabled = true;
  try {
    const res  = await fetch('/settings/backup-now', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();
    const msg  = document.getElementById('backupNowMsg');
    msg.className = `alert alert-${data.success ? 'success' : 'danger'} py-2 small mb-0 mt-2 border-0`;
    msg.innerHTML = `<i class="bi bi-${data.success ? 'check-circle' : 'exclamation-triangle'}-fill me-2"></i>${data.message}`;
    msg.classList.remove('d-none');
    setTimeout(() => msg.classList.add('d-none'), 5000);
  } finally {
    btn.querySelector('.btn-text').classList.remove('d-none');
    btn.querySelector('.btn-loader').classList.add('d-none');
    btn.disabled = false;
  }
}
</script>