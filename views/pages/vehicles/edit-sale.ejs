<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-pencil me-2 text-warning"></i>Edit Van Sale</h2>
      <p class="page-subtitle"><%= sale.invoiceNo %> · <%= sale.vehicle.name %></p>
    </div>
    <div class="page-actions">
      <a href="/vehicles/sales/<%= sale.id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Back</a>
    </div>
  </div>

  <% if (sale.updatedBy) { %>
  <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-clock-history"></i>
    Last edited by <strong><%= sale.updatedBy.name %></strong> on <%= new Date(sale.updatedAt).toLocaleString('en-IN') %>
  </div>
  <% } %>

  <div id="editAlert" class="d-none mb-3"></div>

  <div class="row g-4">
    <div class="col-xl-8">
      <div class="card erp-card mb-3">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-truck me-2 text-success"></i>Vehicle: <%= sale.vehicle.name %> (<%= sale.vehicle.regNo %>)</h5></div>
        <div class="card-body py-2">
          <div class="alert alert-info small py-2 mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Products shown are currently loaded on this vehicle. Old quantities will be restored before saving.
          </div>
        </div>
      </div>

      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-list-ul me-2"></i>Sale Items</h5></div>
        <div class="card-body">
          <div class="row g-3 mb-3" style="position:relative">
            <div class="col-md-8">
              <label class="form-label small fw-medium">Add / Replace Product</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" id="productSearch" placeholder="Search van stock...">
              </div>
              <div id="productDropdown" class="product-dropdown d-none"></div>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table erp-table">
              <thead><tr><th>Product</th><th style="width:90px">Qty</th><th style="width:110px">Price</th><th style="width:75px">Tax%</th><th style="width:120px">Total</th><th style="width:45px"></th></tr></thead>
              <tbody id="saleItems"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="card erp-card mb-4">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-sliders me-2"></i>Details</h5></div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label small fw-medium">Customer</label>
            <select class="form-select" id="customerId">
              <option value="">Walk-in Customer</option>
              <% customers.forEach(c => { %>
              <option value="<%= c.id %>" <%= sale.customerId === c.id ? 'selected' : '' %>><%= c.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Sale Date</label>
            <input type="date" class="form-control" id="saleDate" value="<%= new Date(sale.saleDate).toISOString().split('T')[0] %>">
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Payment Mode</label>
            <select class="form-select" id="paymentMode">
              <% ['CASH','CARD','UPI','BANK_TRANSFER','CREDIT'].forEach(m => { %>
              <option value="<%= m %>" <%= sale.paymentMode === m ? 'selected' : '' %>><%= m.replace('_',' ') %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Status</label>
            <select class="form-select" id="saleStatus">
              <% ['PAID','PARTIAL','UNPAID'].forEach(s => { %>
              <option value="<%= s %>" <%= sale.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Notes</label>
            <textarea class="form-control" id="saleNotes" rows="2"><%= sale.notes || '' %></textarea>
          </div>
        </div>
      </div>

      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-calculator me-2"></i>Summary</h5></div>
        <div class="card-body">
          <div class="invoice-summary">
            <div class="summary-row"><span>Subtotal</span><span id="sumSubtotal">₹0.00</span></div>
            <div class="summary-row"><span>Tax</span><span id="sumTax">₹0.00</span></div>
            <div class="summary-row">
              <span>Discount (₹)</span>
              <input type="number" class="form-control form-control-sm w-50 text-end" id="discountInput" value="<%= sale.discount || 0 %>" min="0" step="0.01" oninput="calcTotals()">
            </div>
            <hr>
            <div class="summary-row summary-total"><span>Total</span><span id="sumTotal">₹0.00</span></div>
          </div>
          <div class="d-grid gap-2 mt-3">
            <button class="btn btn-warning btn-lg" id="saveBtn" onclick="saveEdit()">
              <span class="btn-text"><i class="bi bi-check-circle me-2"></i>Save Changes</span>
              <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Saving...</span>
            </button>
            <a href="/vehicles/sales/<%= sale.id %>" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const SALE_ID    = <%= sale.id %>;
const VEHICLE_ID = <%= sale.vehicle.id %>;

// Pre-load existing items
let saleItems = <%- JSON.stringify(sale.items.map(i => ({
  productId: i.productId,
  name:      i.product.name,
  sku:       i.product.sku,
  price:     parseFloat(i.price),
  tax:       parseFloat(i.tax),
  qty:       i.quantity,
  unit:      i.product.unit,
  maxQty:    999  // will update from API
}))) %>;

// Also keep a live cache of vehicle stock
let vehicleStockCache = {};

// Load current vehicle stock to know max quantities
async function loadVehicleStock() {
  try {
    const res    = await fetch(`/vehicles/api/${VEHICLE_ID}/stock`);
    const stocks = await res.json();
    stocks.forEach(s => { vehicleStockCache[s.id] = s.vehicleStock; });
    // Update maxQty — existing items on sale have their qty already "returned" logically
    saleItems.forEach(item => {
      const onVan = vehicleStockCache[item.productId] || 0;
      item.maxQty = onVan + item.qty; // vehicle has current stock + what this sale used
    });
    renderItems();
    calcTotals();
  } catch (e) { console.error(e); }
}

loadVehicleStock();

// Product search from vehicle stock
let searchTimer;
document.getElementById('productSearch').addEventListener('input', function() {
  clearTimeout(searchTimer);
  const q = this.value.trim();
  if (q.length < 1) { document.getElementById('productDropdown').classList.add('d-none'); return; }
  searchTimer = setTimeout(() => fetchVanProducts(q), 300);
});

async function fetchVanProducts(query) {
  const res    = await fetch(`/vehicles/api/${VEHICLE_ID}/stock?search=${encodeURIComponent(query)}`);
  const stocks = await res.json();
  const dd     = document.getElementById('productDropdown');
  dd.innerHTML = stocks.length
    ? stocks.map(p => {
        const onVan = p.vehicleStock;
        const inSale = saleItems.find(i => i.productId === p.id);
        const avail = onVan + (inSale ? inSale.qty : 0);
        return `<div class="dropdown-item product-item" onclick='addProduct(${JSON.stringify({...p, maxQty: avail})})'>
          <div class="d-flex justify-content-between">
            <div><div class="fw-medium">${p.name}</div><small class="text-muted">${p.sku}</small></div>
            <div class="text-end"><div class="fw-semibold text-success">₹${parseFloat(p.price).toFixed(2)}</div>
            <small class="badge bg-light text-dark border">${avail} ${p.unit} avail</small></div>
          </div></div>`;
      }).join('')
    : '<div class="dropdown-item text-muted">No products on this vehicle</div>';
  dd.classList.remove('d-none');
}

function addProduct(p) {
  document.getElementById('productDropdown').classList.add('d-none');
  document.getElementById('productSearch').value = '';
  const existing = saleItems.find(i => i.productId === p.id);
  if (existing) { existing.qty = Math.min(existing.qty + 1, existing.maxQty); renderItems(); calcTotals(); return; }
  saleItems.push({ productId: p.id, name: p.name, sku: p.sku, price: parseFloat(p.price), tax: parseFloat(p.tax), qty: 1, unit: p.unit, maxQty: p.maxQty || 999 });
  renderItems(); calcTotals();
}

function renderItems() {
  const tbody = document.getElementById('saleItems');
  if (!saleItems.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-center py-3 text-muted">No items</td></tr>'; return; }
  tbody.innerHTML = saleItems.map((item, idx) => {
    const t = item.price * item.qty * (1 + item.tax / 100);
    return `<tr>
      <td><div class="fw-medium">${item.name}</div><small class="text-muted">${item.sku}</small></td>
      <td><input type="number" class="form-control form-control-sm" value="${item.qty}" min="1" max="${item.maxQty}" onchange="updateQty(${idx},this.value)" style="width:70px">
          <small class="text-muted">max ${item.maxQty}</small></td>
      <td><input type="number" class="form-control form-control-sm" value="${item.price}" min="0" step="0.01" onchange="updatePrice(${idx},this.value)" style="width:90px"></td>
      <td class="text-muted">${item.tax}%</td>
      <td class="fw-semibold">₹${t.toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2})}</td>
      <td><button class="btn btn-sm btn-outline-danger" onclick="removeItem(${idx})"><i class="bi bi-trash"></i></button></td>
    </tr>`;
  }).join('');
}

function updateQty(idx, v)   { saleItems[idx].qty = Math.max(1, Math.min(parseInt(v)||1, saleItems[idx].maxQty)); renderItems(); calcTotals(); }
function updatePrice(idx, v) { saleItems[idx].price = parseFloat(v)||0; renderItems(); calcTotals(); }
function removeItem(idx)     { saleItems.splice(idx,1); renderItems(); calcTotals(); }

function calcTotals() {
  let sub = 0, tax = 0;
  saleItems.forEach(i => { const b = i.price * i.qty; sub += b; tax += (b * i.tax)/100; });
  const disc = parseFloat(document.getElementById('discountInput').value)||0;
  document.getElementById('sumSubtotal').textContent = `₹${sub.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumTax').textContent      = `₹${tax.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumTotal').textContent    = `₹${(sub+tax-disc).toLocaleString('en-IN',{minimumFractionDigits:2})}`;
}

async function saveEdit() {
  if (!saleItems.length) return showAlert('danger', 'Add at least one item.');
  const btn = document.getElementById('saveBtn');
  btn.querySelector('.btn-text').classList.add('d-none');
  btn.querySelector('.btn-loader').classList.remove('d-none');
  btn.disabled = true;
  try {
    const res = await fetch(`/vehicles/sales/${SALE_ID}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        customerId:  document.getElementById('customerId').value  || null,
        paymentMode: document.getElementById('paymentMode').value,
        status:      document.getElementById('saleStatus').value,
        saleDate:    document.getElementById('saleDate').value,
        discount:    document.getElementById('discountInput').value,
        notes:       document.getElementById('saleNotes').value,
        items:       saleItems.map(i => ({ productId: i.productId, quantity: i.qty, price: i.price, tax: i.tax }))
      })
    });
    const data = await res.json();
    if (data.success) {
      showAlert('success', data.message);
      setTimeout(() => window.location.href = `/vehicles/sales/${SALE_ID}`, 1200);
    } else {
      showAlert('danger', data.message);
      btn.querySelector('.btn-text').classList.remove('d-none');
      btn.querySelector('.btn-loader').classList.add('d-none');
      btn.disabled = false;
    }
  } catch {
    showAlert('danger', 'Network error.');
    btn.querySelector('.btn-text').classList.remove('d-none');
    btn.querySelector('.btn-loader').classList.add('d-none');
    btn.disabled = false;
  }
}

function showAlert(type, msg) {
  const el = document.getElementById('editAlert');
  el.className = `alert alert-${type}`;
  el.innerHTML = `<i class="bi bi-${type==='success'?'check-circle':'exclamation-triangle'}-fill me-2"></i>${msg}`;
  el.classList.remove('d-none');
}

document.addEventListener('click', e => {
  if (!e.target.closest('#productSearch') && !e.target.closest('#productDropdown'))
    document.getElementById('productDropdown').classList.add('d-none');
});
</script>
