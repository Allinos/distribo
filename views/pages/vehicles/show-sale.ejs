<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-truck me-2 text-success"></i>Van Sale: <%= sale.invoiceNo %></h2>
      <p class="page-subtitle"><%= sale.vehicle.name %> · <%= new Date(sale.saleDate).toLocaleDateString('en-IN', {dateStyle:'long'}) %></p>
    </div>
    <div class="page-actions">
      <a href="/vehicles/sales" class="btn btn-outline-secondary me-2 no-print"><i class="bi bi-arrow-left me-2"></i>Back</a>
      <button class="btn btn-outline-primary no-print me-2" onclick="window.print()"><i class="bi bi-printer me-2"></i>Print</button>
      <% if (sale.status !== 'CANCELLED') { %>
      <a href="/vehicles/sales/<%= sale.id %>/edit" class="btn btn-outline-warning no-print me-2">
        <i class="bi bi-pencil me-2"></i>Edit
      </a>
      <form action="/vehicles/sales/<%= sale.id %>/cancel" method="POST" class="d-inline no-print"
        onsubmit="return confirm('Cancel this van sale? Stock will be restored to vehicle.')">
        <button class="btn btn-outline-danger"><i class="bi bi-x-circle me-2"></i>Cancel</button>
      </form>
      <% } %>
    </div>
  </div>

  <% if (sale.updatedBy) { %>
  <div class="alert alert-info d-flex gap-2 align-items-center mb-3 no-print">
    <i class="bi bi-clock-history"></i>
    Last edited by <strong><%= sale.updatedBy.name %></strong> on <%= new Date(sale.updatedAt).toLocaleString('en-IN') %>
  </div>
  <% } %>

  <div class="invoice-wrapper">
    <div class="invoice-doc">
      <div class="invoice-header" style="background:linear-gradient(135deg,#064e3b,#059669)">
        <div class="invoice-company">
          <div class="company-logo-text"><i class="bi bi-truck"></i></div>
          <div>
            <h2 class="company-name"><%= companyName %></h2>
            <p class="company-sub">Van Sale Invoice</p>
          </div>
        </div>
        <div class="invoice-meta">
          <h1 class="invoice-number">VAN</h1>
          <div class="invoice-details">
            <div class="detail-row"><span class="detail-label">Invoice</span><span class="detail-value fw-bold"><%= sale.invoiceNo %></span></div>
            <div class="detail-row"><span class="detail-label">Vehicle</span><span class="detail-value"><%= sale.vehicle.name %> — <%= sale.vehicle.regNo %></span></div>
            <div class="detail-row"><span class="detail-label">Date</span><span class="detail-value"><%= new Date(sale.saleDate).toLocaleDateString('en-IN') %></span></div>
            <div class="detail-row"><span class="detail-label">Payment</span><span class="detail-value"><%= sale.paymentMode %></span></div>
            <div class="detail-row"><span class="detail-label">By</span><span class="detail-value"><%= sale.user.name %></span></div>
            <div class="detail-row"><span class="detail-label">Status</span>
              <span class="detail-value">
                <span class="badge bg-<%= sale.status==='PAID'?'success':sale.status==='CANCELLED'?'danger':'warning' %>"><%= sale.status %></span>
              </span>
            </div>
          </div>
        </div>
      </div>

      <% if (sale.customer) { %>
      <div class="invoice-bill-to">
        <h6 class="bill-title">CUSTOMER</h6>
        <div class="bill-name"><%= sale.customer.name %></div>
        <% if (sale.customer.phone) { %><div class="bill-detail"><i class="bi bi-telephone me-1"></i><%= sale.customer.phone %></div><% } %>
        <% if (sale.customer.address) { %><div class="bill-detail"><i class="bi bi-geo-alt me-1"></i><%= sale.customer.address %></div><% } %>
      </div>
      <% } %>

      <div class="invoice-items">
        <table class="table invoice-table">
          <thead>
            <tr><th>#</th><th>Product</th><th class="text-center">Qty</th><th class="text-end">Price</th><th class="text-center">Tax</th><th class="text-end">Total</th></tr>
          </thead>
          <tbody>
            <% sale.items.forEach((item, idx) => { %>
            <tr>
              <td><%= idx+1 %></td>
              <td><div class="fw-medium"><%= item.product.name %></div><small class="text-muted"><%= item.product.sku %></small></td>
              <td class="text-center"><%= item.quantity %> <%= item.product.unit %></td>
              <td class="text-end"><%= currency %><%= parseFloat(item.price).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
              <td class="text-center text-muted"><%= item.tax %>%</td>
              <td class="text-end fw-semibold"><%= currency %><%= parseFloat(item.total).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="invoice-totals">
        <div class="totals-table">
          <div class="total-row"><span>Subtotal</span><span><%= currency %><%= parseFloat(sale.subtotal).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span></div>
          <div class="total-row"><span>Tax</span><span><%= currency %><%= parseFloat(sale.taxAmount).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span></div>
          <% if (parseFloat(sale.discount) > 0) { %>
          <div class="total-row text-success"><span>Discount</span><span>− <%= currency %><%= parseFloat(sale.discount).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span></div>
          <% } %>
          <div class="total-row total-grand"><span>TOTAL</span><span><%= currency %><%= parseFloat(sale.total).toLocaleString('en-IN',{minimumFractionDigits:2}) %></span></div>
        </div>
      </div>
      <% if (sale.notes) { %><div class="invoice-notes"><strong>Notes:</strong> <%= sale.notes %></div><% } %>
      <div class="invoice-footer-note"><p>Van Sale · <%= companyName %></p></div>
    </div>
  </div>
</div>
<style>
@media print {
  .no-print,.app-header,.sidebar,.app-footer,.page-header { display:none!important; }
  .main-content { margin-left:0!important; }
  .invoice-doc { box-shadow:none;border:none; }
}
</style>
