<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-truck-front me-2 text-primary"></i><%= vehicle.name %> — Stock</h2>
      <p class="page-subtitle">
        <code class="sku-code"><%= vehicle.regNo %></code>
        <% if (vehicle.driver) { %><span class="ms-2 text-muted">· Driver: <%= vehicle.driver.name %></span><% } %>
      </p>
    </div>
    <div class="page-actions">
      <a href="/vehicles" class="btn btn-outline-secondary me-2"><i class="bi bi-arrow-left me-2"></i>Back</a>
      <a href="/vehicles/sales/new?vehicleId=<%= vehicle.id %>" class="btn btn-success">
        <i class="bi bi-plus me-2"></i>New Van Sale
      </a>
    </div>
  </div>

  <div id="stockAlert" class="d-none mb-3"></div>

  <div class="row g-4">
    <!-- Load / Return Panel -->
    <div class="col-xl-4">
      <!-- Load Stock -->
      <div class="card erp-card mb-4">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-box-arrow-in-right me-2 text-primary"></i>Load Stock onto Van</h5>
          <small class="text-muted">Warehouse → Vehicle</small>
        </div>
        <div class="card-body">
          <div class="alert alert-info small py-2 mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Stock moves from warehouse to the van. Product total stays the same.
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Product <span class="text-danger">*</span></label>
            <select class="form-select" id="assignProduct" onchange="updateAssignInfo()">
              <option value="">Select product...</option>
              <% products.forEach(p => { %>
              <option value="<%= p.id %>"
                data-wh-stock="<%= p.warehouseStock %>"
                data-vs-stock="<%= p.vehicleStock %>"
                data-unit="<%= p.unit %>">
                <%= p.name %> — WH: <%= p.warehouseStock %> / Van: <%= p.vehicleStock %> <%= p.unit %>
              </option>
              <% }) %>
            </select>
            <div class="form-text mt-1" id="assignInfo"></div>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Quantity <span class="text-danger">*</span></label>
            <div class="input-group">
              <input type="number" class="form-control" id="assignQty" min="1" value="1">
              <span class="input-group-text" id="assignUnit">units</span>
            </div>
          </div>
          <button class="btn btn-primary w-100" onclick="assignStock()">
            <i class="bi bi-box-arrow-in-right me-2"></i>Load onto Van
          </button>
        </div>
      </div>

      <!-- Return Stock -->
      <div class="card erp-card">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-box-arrow-left me-2 text-warning"></i>Return Stock to Warehouse</h5>
          <small class="text-muted">Vehicle → Warehouse</small>
        </div>
        <div class="card-body">
          <div class="alert alert-warning small py-2 mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Unsold stock returns to the default warehouse. Product total stays the same.
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Product</label>
            <select class="form-select" id="returnProduct" onchange="updateReturnInfo()">
              <option value="">Select product...</option>
              <% products.filter(p => p.vehicleStock > 0).forEach(p => { %>
              <option value="<%= p.id %>"
                data-vs-stock="<%= p.vehicleStock %>"
                data-unit="<%= p.unit %>">
                <%= p.name %> (on van: <%= p.vehicleStock %> <%= p.unit %>)
              </option>
              <% }) %>
            </select>
            <div class="form-text mt-1" id="returnInfo"></div>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Quantity</label>
            <div class="input-group">
              <input type="number" class="form-control" id="returnQty" min="1" value="1">
              <span class="input-group-text" id="returnUnit">units</span>
            </div>
          </div>
          <button class="btn btn-warning w-100" onclick="returnStock()">
            <i class="bi bi-box-arrow-left me-2"></i>Return to Warehouse
          </button>
        </div>
      </div>
    </div>

    <!-- Current Van Stock Table -->
    <div class="col-xl-8">
      <div class="card erp-card">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-box-seam me-2"></i>Current Van Stock</h5>
          <div class="d-flex gap-2">
            <span class="badge bg-success"><%= products.filter(p => p.vehicleStock > 0).length %> loaded</span>
            <span class="badge bg-light text-dark border"><%= products.reduce((s,p) => s + p.vehicleStock, 0) %> total units</span>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover erp-table mb-0">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Category</th>
                  <th class="text-center">On Van</th>
                  <th class="text-center">In Warehouse</th>
                  <th class="text-center">Total Stock</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (!products.length) { %>
                <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-2 d-block mb-2"></i>No stock information</td></tr>
                <% } %>
                <% products.forEach(p => { %>
                <tr class="<%= p.vehicleStock === 0 ? '' : '' %>">
                  <td>
                    <div class="fw-medium"><%= p.name %></div>
                    <code class="sku-code"><%= p.sku %></code>
                  </td>
                  <td><span class="badge bg-light text-dark border"><%= p.category.name %></span></td>
                  <td class="text-center">
                    <span class="fw-bold <%= p.vehicleStock === 0 ? 'text-muted' : 'text-primary' %>">
                      <%= p.vehicleStock %> <%= p.unit %>
                    </span>
                  </td>
                  <td class="text-center text-muted"><%= p.warehouseStock %> <%= p.unit %></td>
                  <td class="text-center">
                    <span class="<%= p.stock > p.minStock ? 'text-success' : p.stock > 0 ? 'text-warning' : 'text-danger' %> fw-medium">
                      <%= p.stock %> <%= p.unit %>
                    </span>
                  </td>
                  <td>
                    <% if (p.vehicleStock === 0) { %>
                      <span class="badge bg-light text-muted border">Not on van</span>
                    <% } else if (p.vehicleStock <= 5) { %>
                      <span class="badge bg-warning text-dark">Low</span>
                    <% } else { %>
                      <span class="badge bg-success">Loaded</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- How it works explainer -->
      <div class="card erp-card mt-4">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-question-circle me-2 text-info"></i>How Van Stock Works</h5></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4 text-center">
              <div class="fw-semibold text-primary mb-1"><i class="bi bi-building me-1"></i>Warehouse → Van</div>
              <div class="small text-muted">When you <strong>load</strong> stock, it moves from the warehouse bucket to the van bucket. Total product stock is unchanged.</div>
            </div>
            <div class="col-md-4 text-center">
              <div class="fw-semibold text-success mb-1"><i class="bi bi-receipt me-1"></i>Van Sale</div>
              <div class="small text-muted">When you <strong>sell</strong> from the van, stock leaves the system. Both van stock and product total decrease.</div>
            </div>
            <div class="col-md-4 text-center">
              <div class="fw-semibold text-warning mb-1"><i class="bi bi-building me-1"></i>Van → Warehouse</div>
              <div class="small text-muted">When you <strong>return</strong> unsold stock, it moves back to the warehouse. Total product stock is unchanged.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const VEHICLE_ID = <%= vehicle.id %>;

function updateAssignInfo() {
  const opt = document.getElementById('assignProduct').options[document.getElementById('assignProduct').selectedIndex];
  if (!opt.value) { document.getElementById('assignInfo').textContent = ''; return; }
  const wh   = opt.dataset.whStock;
  const vs   = opt.dataset.vsStock;
  const unit = opt.dataset.unit;
  document.getElementById('assignUnit').textContent = unit;
  document.getElementById('assignQty').max = wh;
  document.getElementById('assignInfo').innerHTML =
    `<span class="text-primary">In warehouse: <strong>${wh} ${unit}</strong></span> &nbsp;·&nbsp;
     <span class="text-success">On van: <strong>${vs} ${unit}</strong></span>`;
}

function updateReturnInfo() {
  const opt = document.getElementById('returnProduct').options[document.getElementById('returnProduct').selectedIndex];
  if (!opt.value) { document.getElementById('returnInfo').textContent = ''; return; }
  const vs   = opt.dataset.vsStock;
  const unit = opt.dataset.unit;
  document.getElementById('returnUnit').textContent = unit;
  document.getElementById('returnQty').max = vs;
  document.getElementById('returnInfo').innerHTML =
    `<span class="text-warning">On van: <strong>${vs} ${unit}</strong></span>`;
}

async function assignStock() {
  const productId = document.getElementById('assignProduct').value;
  const quantity  = document.getElementById('assignQty').value;
  if (!productId || !quantity) return showAlert('danger', 'Select a product and enter quantity.');
  try {
    const res  = await fetch(`/vehicles/${VEHICLE_ID}/stock/assign`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId, quantity })
    });
    const data = await res.json();
    showAlert(data.success ? 'success' : 'danger', data.message);
    if (data.success) setTimeout(() => location.reload(), 1200);
  } catch { showAlert('danger', 'Network error.'); }
}

async function returnStock() {
  const productId = document.getElementById('returnProduct').value;
  const quantity  = document.getElementById('returnQty').value;
  if (!productId || !quantity) return showAlert('danger', 'Select a product and enter quantity.');
  try {
    const res  = await fetch(`/vehicles/${VEHICLE_ID}/stock/return`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId, quantity })
    });
    const data = await res.json();
    showAlert(data.success ? 'success' : 'danger', data.message);
    if (data.success) setTimeout(() => location.reload(), 1200);
  } catch { showAlert('danger', 'Network error.'); }
}

function showAlert(type, msg) {
  const el = document.getElementById('stockAlert');
  el.className = `alert alert-${type}`;
  el.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'}-fill me-2"></i>${msg}`;
  el.classList.remove('d-none');
  if (type === 'success') setTimeout(() => el.classList.add('d-none'), 5000);
}
</script>
