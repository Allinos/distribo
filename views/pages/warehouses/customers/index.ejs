<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-people me-2 text-primary"></i>Customers</h2>
      <p class="page-subtitle">Manage customers and track their account balances</p>
    </div>
    <div class="page-actions">
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#customerModal">
        <i class="bi bi-plus-lg me-2"></i>Add Customer
      </button>
    </div>
  </div>

  <%- typeof flashMessages !== 'undefined' && flashMessages.success ? `<div class="alert alert-success">${flashMessages.success}</div>` : '' %>
  <%- typeof flashMessages !== 'undefined' && flashMessages.error   ? `<div class="alert alert-danger">${flashMessages.error}</div>` : '' %>

  <!-- Summary row -->
  <% const totalDue = customers.reduce((s,c) => s + Math.max(0, c.balance||0), 0); %>
  <% const totalCustomers = customers.length; %>
  <% const withDue = customers.filter(c => (c.balance||0) > 0).length; %>
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="stat-card stat-card-primary">
        <div class="stat-icon"><i class="bi bi-people"></i></div>
        <div class="stat-content">
          <div class="stat-label">Total Customers</div>
          <div class="stat-value"><%= pagination.total %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card stat-card-danger">
        <div class="stat-icon"><i class="bi bi-clock"></i></div>
        <div class="stat-content">
          <div class="stat-label">With Pending Dues</div>
          <div class="stat-value"><%= withDue %></div>
          <div class="stat-change neutral">on this page</div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card stat-card-warning">
        <div class="stat-icon"><i class="bi bi-currency-rupee"></i></div>
        <div class="stat-content">
          <div class="stat-label">Total Outstanding</div>
          <div class="stat-value">₹<%= totalDue.toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
          <div class="stat-change neutral">on this page</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="card erp-card mb-4">
    <div class="card-body py-3">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-6">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" name="search" value="<%= search %>" placeholder="Name, email or phone...">
          </div>
        </div>
        <div class="col-md-6 d-flex gap-2">
          <button type="submit" class="btn btn-primary">Search</button>
          <a href="/customers" class="btn btn-outline-secondary">Reset</a>
        </div>
      </form>
    </div>
  </div>

  <!-- Table -->
  <div class="card erp-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover erp-table mb-0">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Phone</th>
              <th>GSTIN</th>
              <th class="text-center">Orders</th>
              <th class="text-end">Total Spent</th>
              <th class="text-end">Outstanding</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!customers.length) { %>
            <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-people fs-2 d-block mb-2"></i>No customers found</td></tr>
            <% } %>
            <% customers.forEach(c => { %>
            <tr>
              <td>
                <div class="fw-medium"><%= c.name %></div>
                <small class="text-muted"><%= c.email || '' %></small>
              </td>
              <td class="text-muted"><%= c.phone || '—' %></td>
              <td><% if(c.gstin){ %><code class="small"><%= c.gstin %></code><% }else{ %>—<% } %></td>
              <td class="text-center">
                <span class="badge bg-light text-dark border"><%= c.purchaseCount || 0 %></span>
              </td>
              <td class="text-end fw-medium">₹<%= (c.totalPurchases||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></td>
              <td class="text-end">
                <% if ((c.balance||0) > 0.01) { %>
                  <span class="fw-bold text-danger">₹<%= parseFloat(c.balance).toLocaleString('en-IN',{maximumFractionDigits:0}) %></span>
                <% } else { %>
                  <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Clear -<%= c.balance %> </span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/customers/<%= c.id %>/ledger" class="btn btn-sm btn-outline-info me-1" title="View Ledger & Payments">
                  <i class="bi bi-journal-text"></i>
                </a>
                <% if ((c.balance||0) > 0.01) { %>
                <a href="/customers/<%= c.id %>/ledger" class="btn btn-sm btn-success me-1" title="Collect Payment">
                  <i class="bi bi-cash"></i>
                </a>
                <% } %>
                <button class="btn btn-sm btn-outline-primary me-1" onclick='editCustomer(<%- JSON.stringify({id:c.id,name:c.name,email:c.email,phone:c.phone,address:c.address,gstin:c.gstin}) %>)' title="Edit">
                  <i class="bi bi-pencil"></i>
                </button>
                <form action="/customers/<%= c.id %>?_method=DELETE" method="POST" class="d-inline"
                  onsubmit="return confirm('Delete <%= c.name %>? This cannot be undone.')">
                  <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% if (pagination.totalPages > 1) { %>
    <div class="card-footer d-flex justify-content-between align-items-center">
      <small class="text-muted">Showing <%= (pagination.page-1)*pagination.limit+1 %>–<%= Math.min(pagination.page*pagination.limit,pagination.total) %> of <%= pagination.total %></small>
      <%- include('../../partials/pagination', { query: { search } }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- Add/Edit Customer Modal -->
<div class="modal fade" id="customerModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form id="customerForm" method="POST" action="/customers">
        <input type="hidden" name="_method" id="customerMethod" value="POST">
        <input type="hidden" id="customerId">
        <div class="modal-header">
          <h5 class="modal-title" id="customerModalTitle"><i class="bi bi-person-plus me-2"></i>Add Customer</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-medium">Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="name" id="custName" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Phone</label>
              <input type="text" class="form-control" name="phone" id="custPhone">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Email</label>
              <input type="email" class="form-control" name="email" id="custEmail">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Address</label>
              <textarea class="form-control" name="address" id="custAddress" rows="2"></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">GSTIN</label>
              <input type="text" class="form-control" name="gstin" id="custGstin" placeholder="Optional">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Save Customer</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function editCustomer(c) {
  document.getElementById('customerModalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Edit Customer';
  document.getElementById('customerForm').action = `/customers/${c.id}`;
  document.getElementById('customerMethod').value = 'PUT';
  document.getElementById('custName').value    = c.name    || '';
  document.getElementById('custPhone').value   = c.phone   || '';
  document.getElementById('custEmail').value   = c.email   || '';
  document.getElementById('custAddress').value = c.address || '';
  document.getElementById('custGstin').value   = c.gstin   || '';
  new bootstrap.Modal(document.getElementById('customerModal')).show();
}

document.getElementById('customerModal').addEventListener('hidden.bs.modal', () => {
  document.getElementById('customerForm').action = '/customers';
  document.getElementById('customerMethod').value = 'POST';
  document.getElementById('customerModalTitle').innerHTML = '<i class="bi bi-person-plus me-2"></i>Add Customer';
  document.getElementById('customerForm').reset();
});
</script>
