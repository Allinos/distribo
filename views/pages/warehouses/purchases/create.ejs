<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-bag-plus me-2 text-primary"></i>New Purchase Order</h2>
      <p class="page-subtitle">PO # <strong id="poNoDisplay"><%= poNo %></strong></p>
    </div>
    <div class="page-actions">
      <a href="/purchases" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Back</a>
    </div>
  </div>

  <div id="poAlert" class="d-none mb-3"></div>

  <div class="row g-4">
    <!-- Left: Supplier + Products -->
    <div class="col-xl-8">

      <!-- Supplier + Product Search -->
      <div class="card erp-card mb-3">
        <div class="card-body py-3">
          <div class="row g-3 align-items-end">
            <div class="col-md-5">
              <label class="form-label small fw-medium">Supplier <span class="text-danger">*</span></label>
              <select class="form-select" id="supplierId">
                <option value="">— Select supplier —</option>
                <% suppliers.forEach(s => { %>
                <option value="<%= s.id %>"><%= s.name %><% if(s.phone){ %> · <%= s.phone %><% } %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-7" style="position:relative">
              <label class="form-label small fw-medium">Search / Add Product</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" id="productSearch" placeholder="Type name or SKU to search...">
              </div>
              <div id="productDropdown" class="product-dropdown d-none"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- POS Product Grid (all active products) -->
      <div class="card erp-card mb-3">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-grid me-2 text-primary"></i>Quick Add Product</h5>
          <small class="text-muted">Click to add to order</small>
        </div>
        <div class="card-body p-2">
          <div id="posProductGrid" class="pos-grid">
            <p class="text-muted small p-2">Loading products...</p>
          </div>
        </div>
      </div>

      <!-- Items table -->
      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-list-ul me-2"></i>Purchase Items</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table erp-table mb-0">
              <thead>
                <tr>
                  <th>Product</th>
                  <th style="width:85px">Qty</th>
                  <th style="width:130px">Cost Price (₹)</th>
                  <th style="width:70px">Tax%</th>
                  <th style="width:120px">Total</th>
                  <th style="width:36px"></th>
                </tr>
              </thead>
              <tbody id="poItems">
                <tr id="emptyRow">
                  <td colspan="6" class="text-center py-4 text-muted">
                    <i class="bi bi-grid fs-3 d-block mb-2"></i>Click products above to add them
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Details + Summary -->
    <div class="col-xl-4">
      <div class="card erp-card mb-3">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-sliders me-2"></i>Order Details</h5></div>
        <div class="card-body">
          <div class="mb-2">
            <label class="form-label small fw-medium">Warehouse</label>
            <select class="form-select form-select-sm" id="warehouseId">
              <option value="">— No specific warehouse —</option>
              <% warehouses.forEach(w => { %>
              <option value="<%= w.id %>" <%= w.isDefault ? 'selected' : '' %>><%= w.name %><% if(w.isDefault){%> ★<%}%></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label small fw-medium">Status</label>
            <select class="form-select form-select-sm" id="poStatus">
              <option value="RECEIVED">✅ Received (updates stock)</option>
              <option value="ORDERED">📋 Ordered (no stock yet)</option>
              <option value="PARTIAL">⏳ Partial</option>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label small fw-medium">Purchase Date</label>
            <input type="date" class="form-control form-control-sm" id="purchaseDate"
              value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div>
            <label class="form-label small fw-medium">Notes</label>
            <textarea class="form-control form-control-sm" id="poNotes" rows="2" placeholder="Optional..."></textarea>
          </div>
        </div>
      </div>

      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-calculator me-2"></i>Summary</h5></div>
        <div class="card-body">
          <div class="invoice-summary">
            <div class="summary-row"><span>Subtotal</span><span id="sumSubtotal">₹0.00</span></div>
            <div class="summary-row"><span>Tax</span><span id="sumTax">₹0.00</span></div>
            <hr class="my-2">
            <div class="summary-row summary-total"><span>Total</span><span id="sumTotal" class="fw-bold">₹0.00</span></div>
          </div>
          <div class="alert alert-info small py-2 mt-3 mb-0">
            <i class="bi bi-info-circle me-1"></i>
            <strong>RECEIVED</strong> status will deduct from supplier and update warehouse stock + WAC.
          </div>
          <button class="btn btn-primary w-100 mt-3 btn-lg" id="saveBtn" onclick="savePO()">
            <span class="btn-text"><i class="bi bi-check-circle me-2"></i>Save Purchase Order</span>
            <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Saving...</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.pos-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(110px,1fr)); gap:6px; max-height:260px; overflow-y:auto; }
.pos-item { border:1px solid var(--color-border-tertiary); border-radius:8px; padding:8px 6px; cursor:pointer; text-align:center; transition:all .15s; background:var(--color-background-primary); }
.pos-item:hover { border-color:#2563eb; background:rgba(37,99,235,.06); }
.pos-item:active { transform:scale(.95); }
.pos-name  { font-size:.75rem; font-weight:600; line-height:1.3; margin-bottom:2px; color:var(--color-text-primary); }
.pos-cost  { font-size:.8rem; color:#2563eb; font-weight:700; }
.pos-stock { font-size:.62rem; color:var(--color-text-tertiary); }
</style>

<script>
const PO_NO = '<%= poNo %>';
let poItems = [], allProducts = [], searchTimer;

// ── Load products on page load ────────────────────────────────────────────────
window.addEventListener('load', async () => {
  try {
    allProducts = await (await fetch('/products/api/list?limit=200')).json();
    renderPOSGrid(allProducts);
  } catch (e) {
    document.getElementById('posProductGrid').innerHTML = '<p class="text-muted small p-2">Failed to load products.</p>';
  }
});

function renderPOSGrid(products) {
  const g = document.getElementById('posProductGrid');
  if (!products.length) { g.innerHTML = '<p class="text-muted small p-2">No products found</p>'; return; }
  g.innerHTML = products.map(p =>
    `<div class="pos-item" onclick='addProduct(${JSON.stringify({id:p.id,name:p.name,sku:p.sku,costPrice:parseFloat(p.costPrice||0),tax:parseFloat(p.tax||0),unit:p.unit||"pcs"})})'>
      <div class="pos-name">${p.name}</div>
      <div class="pos-cost">₹${parseFloat(p.costPrice||0).toLocaleString('en-IN')}</div>
      <div class="pos-stock">Stock: ${p.stock} ${p.unit||'pcs'}</div>
    </div>`
  ).join('');
}

// ── Search ────────────────────────────────────────────────────────────────────
document.getElementById('productSearch').addEventListener('input', function() {
  const q = this.value.trim().toLowerCase();
  if (allProducts.length) renderPOSGrid(q ? allProducts.filter(p => p.name.toLowerCase().includes(q) || p.sku.toLowerCase().includes(q)) : allProducts);
  clearTimeout(searchTimer);
  if (q.length < 2) { document.getElementById('productDropdown').classList.add('d-none'); return; }
  searchTimer = setTimeout(() => {
    const filtered = allProducts.filter(p => p.name.toLowerCase().includes(q) || p.sku.toLowerCase().includes(q));
    const dd = document.getElementById('productDropdown');
    dd.innerHTML = filtered.length
      ? filtered.map(p => `<div class="dropdown-item product-item" onclick='addProduct(${JSON.stringify({id:p.id,name:p.name,sku:p.sku,costPrice:parseFloat(p.costPrice||0),tax:parseFloat(p.tax||0),unit:p.unit||"pcs"})})'>
          <div class="d-flex justify-content-between align-items-center">
            <div><div class="fw-medium">${p.name}</div><small class="text-muted">${p.sku} · Stock: ${p.stock}</small></div>
            <span class="fw-bold text-primary">Cost: ₹${parseFloat(p.costPrice||0).toLocaleString('en-IN')}</span>
          </div></div>`).join('')
      : '<div class="dropdown-item text-muted">No products found</div>';
    dd.classList.remove('d-none');
  }, 200);
});

// ── Items ─────────────────────────────────────────────────────────────────────
function addProduct(p) {
  document.getElementById('productDropdown').classList.add('d-none');
  document.getElementById('productSearch').value = '';
  const ex = poItems.find(i => i.productId === p.id);
  if (ex) { ex.qty++; renderItems(); calcTotals(); return; }
  poItems.push({ productId: p.id, name: p.name, sku: p.sku, price: p.costPrice, tax: p.tax, qty: 1, unit: p.unit });
  renderItems(); calcTotals();
}

function renderItems() {
  const tbody = document.getElementById('poItems');
  document.getElementById('emptyRow')?.remove();
  if (!poItems.length) {
    tbody.innerHTML = '<tr id="emptyRow"><td colspan="6" class="text-center py-4 text-muted"><i class="bi bi-grid fs-3 d-block mb-2"></i>Click products above to add them</td></tr>';
    return;
  }
  tbody.innerHTML = poItems.map((item, idx) => {
    const b = item.price*item.qty, tax = (b*item.tax)/100, t = b+tax;
    return `<tr>
      <td><div class="fw-medium">${item.name}</div><small class="text-muted">${item.sku}</small></td>
      <td><input type="number" class="form-control form-control-sm" value="${item.qty}" min="1"
            onchange="updateQty(${idx},this.value)" style="width:68px"></td>
      <td><input type="number" class="form-control form-control-sm" value="${item.price}" min="0" step="0.01"
            onchange="updatePrice(${idx},this.value)" style="width:110px"></td>
      <td class="text-muted small">${item.tax}%</td>
      <td class="fw-semibold">₹${t.toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2})}</td>
      <td><button class="btn btn-sm btn-outline-danger p-1" onclick="removeItem(${idx})"><i class="bi bi-x"></i></button></td>
    </tr>`;
  }).join('');
}

function updateQty(i, v)   { poItems[i].qty = Math.max(1, parseInt(v)||1); renderItems(); calcTotals(); }
function updatePrice(i, v) { poItems[i].price = parseFloat(v)||0; renderItems(); calcTotals(); }
function removeItem(i)     { poItems.splice(i,1); renderItems(); calcTotals(); }

function calcTotals() {
  let sub=0, tax=0;
  poItems.forEach(i => { const b=i.price*i.qty; sub+=b; tax+=(b*i.tax)/100; });
  document.getElementById('sumSubtotal').textContent = `₹${sub.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumTax').textContent      = `₹${tax.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumTotal').textContent    = `₹${(sub+tax).toLocaleString('en-IN',{minimumFractionDigits:2})}`;
}

// ── Save ──────────────────────────────────────────────────────────────────────
async function savePO() {
  if (!document.getElementById('supplierId').value) return showAlert('danger', 'Select a supplier.');
  if (!poItems.length) return showAlert('danger', 'Add at least one product.');

  const btn = document.getElementById('saveBtn');
  btn.querySelector('.btn-text').classList.add('d-none');
  btn.querySelector('.btn-loader').classList.remove('d-none');
  btn.disabled = true;

  try {
    const res  = await fetch('/purchases', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        poNo:         PO_NO,
        supplierId:   document.getElementById('supplierId').value,
        warehouseId:  document.getElementById('warehouseId').value || null,
        status:       document.getElementById('poStatus').value,
        purchaseDate: document.getElementById('purchaseDate').value,
        notes:        document.getElementById('poNotes').value,
        items:        poItems.map(i => ({ productId: i.productId, quantity: i.qty, price: i.price, tax: i.tax }))
      })
    });
    const data = await res.json();
    if (data.success) {
      showAlert('success', data.message || 'Purchase order saved.');
      setTimeout(() => window.location.href = `/purchases/${data.purchaseId}`, 1200);
    } else {
      showAlert('danger', data.message);
      btn.querySelector('.btn-text').classList.remove('d-none');
      btn.querySelector('.btn-loader').classList.add('d-none');
      btn.disabled = false;
    }
  } catch {
    showAlert('danger', 'Network error.');
    btn.querySelector('.btn-text').classList.remove('d-none');
    btn.querySelector('.btn-loader').classList.add('d-none');
    btn.disabled = false;
  }
}

function showAlert(type, msg) {
  const el = document.getElementById('poAlert');
  el.className = `alert alert-${type}`;
  el.innerHTML = `<i class="bi bi-${type==='success'?'check-circle':'exclamation-triangle'}-fill me-2"></i>${msg}`;
  el.classList.remove('d-none');
  el.scrollIntoView({ behavior:'smooth', block:'start' });
}

document.addEventListener('click', e => {
  if (!e.target.closest('#productSearch') && !e.target.closest('#productDropdown'))
    document.getElementById('productDropdown').classList.add('d-none');
});
</script>
