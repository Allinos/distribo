<div class="page-content">
  <div class="page-header">
    <div><h2 class="page-title">New Invoice</h2><p class="page-subtitle">Invoice # <strong><%= invoiceNo %></strong></p></div>
    <div class="page-actions"><a href="/sales" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Back</a></div>
  </div>
  <div id="invoiceAlert" class="d-none mb-3"></div>
  <div class="row g-4">

    <!-- Left: Product selection + items -->
    <div class="col-xl-8">
      <!-- Warehouse + Search -->
      <div class="card erp-card mb-3">
        <div class="card-body py-3">
          <div class="row g-3 align-items-end">
            <div class="col-md-4">
              <label class="form-label small fw-medium">Warehouse</label>
              <select class="form-select" id="warehouseId" onchange="onWarehouseChange()">
                <option value="">— No specific warehouse —</option>
                <% warehouses.forEach(w => { %>
                <option value="<%= w.id %>" <%= (typeof defaultWarehouseId!=='undefined'&&defaultWarehouseId===w.id)?'selected':'' %>>
                  <%= w.name %><% if(w.isDefault){%> ★<%}%>
                </option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-8" style="position:relative">
              <label class="form-label small fw-medium">Search Product</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" id="productSearch" placeholder="Type name or SKU to search or filter grid...">
              </div>
              <div id="productDropdown" class="product-dropdown d-none"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- POS Product Grid -->
      <div id="posGrid" class="d-none mb-3">
        <div class="card erp-card">
          <div class="card-header">
            <h5 class="card-title"><i class="bi bi-grid me-2"></i>Quick Select</h5>
            <small class="text-muted">Click to add · Double-click amount field to auto-fill</small>
          </div>
          <div class="card-body p-2">
            <div id="posProductGrid" class="pos-grid"></div>
          </div>
        </div>
      </div>

      <!-- Invoice Items Table -->
      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-list-ul me-2"></i>Invoice Items</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table erp-table mb-0">
              <thead>
                <tr>
                  <th>Product</th>
                  <th style="width:80px">Qty</th>
                  <th style="width:110px">Price (₹)</th>
                  <th style="width:68px">Tax%</th>
                  <th style="width:100px">Discount</th>
                  <th style="width:115px">Total</th>
                  <th style="width:36px"></th>
                </tr>
              </thead>
              <tbody id="invoiceItems">
                <tr id="emptyRow"><td colspan="7" class="text-center py-4 text-muted"><i class="bi bi-cart-plus fs-3 d-block mb-2"></i>Add products above or click from grid</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Details + Payments -->
    <div class="col-xl-4">
      <!-- Customer & Details -->
      <div class="card erp-card mb-3">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-person me-2"></i>Details</h5></div>
        <div class="card-body">
          <div class="mb-2">
            <label class="form-label small fw-medium">Customer</label>
            <select class="form-select form-select-sm" id="customerId">
              <option value="">Walk-in Customer</option>
              <% customers.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %><%= c.phone?` (${c.phone})`:'' %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label small fw-medium">Sale Date</label>
            <input type="date" class="form-control form-control-sm" id="saleDate" value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div>
            <label class="form-label small fw-medium">Notes</label>
            <textarea class="form-control form-control-sm" id="invoiceNotes" rows="2" placeholder="Optional..."></textarea>
          </div>
        </div>
      </div>

      <!-- Totals -->
      <div class="card erp-card mb-3">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-calculator me-2"></i>Summary</h5></div>
        <div class="card-body">
          <div class="invoice-summary">
            <div class="summary-row"><span>Subtotal</span><span id="sumSubtotal">₹0.00</span></div>
            <div class="summary-row"><span>Tax</span><span id="sumTax">₹0.00</span></div>
            <div class="summary-row"><span>Discounts</span><span id="sumDiscount" class="text-success">₹0.00</span></div>
            <hr class="my-2">
            <div class="summary-row summary-total"><span>Invoice Total</span><span id="sumTotal" class="fw-bold">₹0.00</span></div>
            <div class="summary-row mt-1" style="font-size:.82rem">
              <span class="text-muted">Amount Paid</span>
              <span id="sumPaid" class="text-success fw-semibold">₹0.00</span>
            </div>
            <div class="summary-row" style="font-size:.82rem">
              <span class="text-muted">Credit / Due</span>
              <span id="sumCredit" class="fw-semibold">₹0.00</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Split Payments -->
      <div class="card erp-card">
        <div class="card-header">
          <h5 class="card-title"><i class="bi bi-cash-stack me-2"></i>Payments</h5>
          <button class="btn btn-sm btn-outline-primary" onclick="addPaymentRow()">
            <i class="bi bi-plus me-1"></i>Add Method
          </button>
        </div>
        <div class="card-body p-2" id="paymentsContainer"></div>
        <div class="card-footer">
          <button class="btn btn-success w-100 btn-lg" id="saveInvoiceBtn" onclick="saveInvoice()">
            <span class="btn-text"><i class="bi bi-check-circle me-2"></i>Save Invoice</span>
            <span class="btn-loader d-none"><span class="spinner-border spinner-border-sm me-2"></span>Saving...</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.pos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:6px}
.pos-item{border:1px solid var(--color-border-tertiary);border-radius:8px;padding:8px 6px;cursor:pointer;text-align:center;transition:all .15s;background:var(--color-background-primary)}
.pos-item:hover{border-color:#6366f1;background:rgba(99,102,241,.06)}
.pos-item:active{transform:scale(.95)}
.pos-name{font-size:.75rem;font-weight:600;line-height:1.3;margin-bottom:2px;color:var(--color-text-primary)}
.pos-price{font-size:.8rem;color:#6366f1;font-weight:700}
.pos-stock{font-size:.62rem;color:var(--color-text-tertiary)}
.pos-item.oos{opacity:.35;pointer-events:none}
.pay-row{display:grid;grid-template-columns:1fr 100px 1fr 26px;gap:4px;margin-bottom:5px;align-items:center}
</style>

<script>
const INVOICE_NO = '<%= invoiceNo %>';
let invoiceItems = [], payments = {}, payIdx = 0, posProducts = [], searchTimer;

// ── Init ──────────────────────────────────────────────────────────────────────
window.addEventListener('load', () => {
  addPaymentRow('CASH');
  const wId = document.getElementById('warehouseId').value;
  if (wId) loadPOSGrid(wId);
});

// ── Warehouse ─────────────────────────────────────────────────────────────────
function onWarehouseChange() {
  const wId = document.getElementById('warehouseId').value;
  if (invoiceItems.length && !confirm('Changing warehouse clears current items. Continue?')) return;
  invoiceItems = []; renderItems(); calcTotals();
  if (wId) loadPOSGrid(wId);
  else { document.getElementById('posGrid').classList.add('d-none'); posProducts = []; }
}

async function loadPOSGrid(wId) {
  try {
    posProducts = await (await fetch(`/products/api/warehouse-list?warehouseId=${wId}`)).json();
    renderPOSGrid(posProducts);
    document.getElementById('posGrid').classList.remove('d-none');
  } catch (e) { console.error(e); }
}

function renderPOSGrid(prods) {
  const g = document.getElementById('posProductGrid');
  if (!prods.length) { g.innerHTML = '<p class="text-muted small p-2">No products in this warehouse</p>'; return; }
  g.innerHTML = prods.map(p =>
    `<div class="pos-item${p.stock===0?' oos':''}" onclick='addProduct(${JSON.stringify({id:p.id,name:p.name,sku:p.sku,price:parseFloat(p.price),tax:parseFloat(p.tax),stock:p.stock,unit:p.unit})})'>
      <div class="pos-name">${p.name}</div>
      <div class="pos-price">₹${parseFloat(p.price).toLocaleString('en-IN')}</div>
      <div class="pos-stock">${p.stock} ${p.unit}</div>
    </div>`
  ).join('');
}

// ── Search ────────────────────────────────────────────────────────────────────
document.getElementById('productSearch').addEventListener('input', function() {
  const q = this.value.trim().toLowerCase();
  if (posProducts.length) renderPOSGrid(q ? posProducts.filter(p => p.name.toLowerCase().includes(q) || p.sku.toLowerCase().includes(q)) : posProducts);
  clearTimeout(searchTimer);
  if (q.length < 2) { document.getElementById('productDropdown').classList.add('d-none'); return; }
  searchTimer = setTimeout(() => fetchSearchProducts(q), 280);
});

async function fetchSearchProducts(q) {
  const wId = document.getElementById('warehouseId').value;
  const url  = wId ? `/products/api/warehouse-list?warehouseId=${wId}&search=${encodeURIComponent(q)}` : `/products/api/list?search=${encodeURIComponent(q)}`;
  const prods = await (await fetch(url)).json();
  const dd = document.getElementById('productDropdown');
  dd.innerHTML = prods.length
    ? prods.map(p => {
        const stock = p.stock !== undefined ? p.stock : p.warehouseStock;
        return `<div class="dropdown-item product-item" onclick='addProduct(${JSON.stringify({id:p.id,name:p.name,sku:p.sku,price:parseFloat(p.price),tax:parseFloat(p.tax),stock,unit:p.unit})})'>
          <div class="d-flex justify-content-between align-items-center">
            <div><div class="fw-medium">${p.name}</div><small class="text-muted">${p.sku} · ${stock} ${p.unit}</small></div>
            <span class="fw-bold text-primary">₹${parseFloat(p.price).toLocaleString('en-IN')}</span>
          </div></div>`;
      }).join('')
    : '<div class="dropdown-item text-muted">No products found</div>';
  dd.classList.remove('d-none');
}

// ── Items ─────────────────────────────────────────────────────────────────────
function addProduct(p) {
  document.getElementById('productDropdown').classList.add('d-none');
  document.getElementById('productSearch').value = '';
  const ex = invoiceItems.find(i => i.productId === p.id);
  if (ex) { ex.qty = Math.min(ex.qty + 1, ex.maxStock); renderItems(); calcTotals(); return; }
  invoiceItems.push({ productId: p.id, name: p.name, sku: p.sku, price: p.price, tax: p.tax, qty: 1, discount: 0, maxStock: p.stock, unit: p.unit });
  renderItems(); calcTotals();
}

function renderItems() {
  const tbody = document.getElementById('invoiceItems');
  document.getElementById('emptyRow')?.remove();
  if (!invoiceItems.length) {
    tbody.innerHTML = '<tr id="emptyRow"><td colspan="7" class="text-center py-4 text-muted"><i class="bi bi-cart-plus fs-3 d-block mb-2"></i>Add products above or click from grid</td></tr>';
    return;
  }
  tbody.innerHTML = invoiceItems.map((item, idx) => {
    const b = item.price * item.qty, tax = (b * item.tax) / 100, t = b + tax - (item.discount || 0);
    return `<tr>
      <td><div class="fw-medium">${item.name}</div><small class="text-muted">${item.sku}</small></td>
      <td><input type="number" class="form-control form-control-sm" value="${item.qty}" min="1" max="${item.maxStock}" onchange="updateQty(${idx},this.value)" style="width:65px"></td>
      <td><input type="number" class="form-control form-control-sm" value="${item.price}" min="0" step="0.01" onchange="updatePrice(${idx},this.value)" style="width:90px"></td>
      <td class="text-muted small">${item.tax}%</td>
      <td><input type="number" class="form-control form-control-sm" value="${item.discount||0}" min="0" step="0.01" onchange="updateDisc(${idx},this.value)" style="width:80px"></td>
      <td class="fw-semibold small">₹${t.toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2})}</td>
      <td><button class="btn btn-sm btn-outline-danger p-1" onclick="removeItem(${idx})"><i class="bi bi-x"></i></button></td>
    </tr>`;
  }).join('');
}

function updateQty(i, v)   { invoiceItems[i].qty = Math.max(1, Math.min(parseInt(v)||1, invoiceItems[i].maxStock)); renderItems(); calcTotals(); }
function updatePrice(i, v) { invoiceItems[i].price = parseFloat(v)||0; renderItems(); calcTotals(); }
function updateDisc(i, v)  { invoiceItems[i].discount = parseFloat(v)||0; renderItems(); calcTotals(); }
function removeItem(i)     { invoiceItems.splice(i,1); renderItems(); calcTotals(); }

// ── Totals ────────────────────────────────────────────────────────────────────
function calcTotals() {
  let sub = 0, tax = 0, disc = 0;
  invoiceItems.forEach(i => { const b = i.price*i.qty; sub+=b; tax+=(b*i.tax)/100; disc+=(i.discount||0); });
  const total = sub + tax - disc;
  document.getElementById('sumSubtotal').textContent = `₹${sub.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumTax').textContent      = `₹${tax.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumDiscount').textContent = `−₹${disc.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumTotal').textContent    = `₹${total.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  refreshPaymentTotal(total);
}

// ── Split Payments ────────────────────────────────────────────────────────────
function addPaymentRow(mode='CASH', amount='') {
  const idx = payIdx++;
  payments[idx] = { mode, amount: parseFloat(amount)||0, reference: '' };
  const container = document.getElementById('paymentsContainer');
  const row = document.createElement('div');
  row.className = 'pay-row'; row.id = `pr-${idx}`;
  row.innerHTML = `
    <select class="form-select form-select-sm" onchange="payments[${idx}].mode=this.value">
      ${['CASH','UPI','CARD','BANK_TRANSFER','CREDIT'].map(m=>`<option value="${m}"${m===mode?' selected':''}>${m.replace('_',' ')}</option>`).join('')}
    </select>
    <input type="number" class="form-control form-control-sm" placeholder="₹" value="${amount||''}"
      oninput="payments[${idx}].amount=parseFloat(this.value)||0;refreshPaymentTotal()"
      ondblclick="autoFillAmount(this,${idx})">
    <input type="text" class="form-control form-control-sm" placeholder="Ref"
      oninput="payments[${idx}].reference=this.value">
    <button class="btn btn-sm btn-outline-danger p-1"
      onclick="document.getElementById('pr-${idx}').remove();delete payments[${idx}];refreshPaymentTotal()">
      <i class="bi bi-x"></i>
    </button>`;
  container.appendChild(row);
  refreshPaymentTotal();
}

function autoFillAmount(input, idx) {
  let sub=0,tax=0,disc=0;
  invoiceItems.forEach(i=>{const b=i.price*i.qty;sub+=b;tax+=(b*i.tax)/100;disc+=(i.discount||0);});
  const total = sub+tax-disc;
  const otherPaid = Object.entries(payments).filter(([i])=>parseInt(i)!==idx).reduce((s,[,p])=>s+(p.amount||0),0);
  const fill = Math.max(0, total - otherPaid);
  input.value = fill.toFixed(2);
  payments[idx].amount = fill;
  refreshPaymentTotal(total);
}

function refreshPaymentTotal(total) {
  if (total === undefined) {
    let sub=0,tax=0,disc=0;
    invoiceItems.forEach(i=>{const b=i.price*i.qty;sub+=b;tax+=(b*i.tax)/100;disc+=(i.discount||0);});
    total = sub+tax-disc;
  }
  const paid   = Object.values(payments).reduce((s,p)=>s+(p.amount||0),0);
  const credit = total - paid;
  document.getElementById('sumPaid').textContent   = `₹${paid.toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumCredit').textContent = `₹${Math.max(0,credit).toLocaleString('en-IN',{minimumFractionDigits:2})}`;
  document.getElementById('sumCredit').className   = credit > 0.01 ? 'fw-semibold text-danger' : 'fw-semibold text-success';
}

// ── Save ──────────────────────────────────────────────────────────────────────
async function saveInvoice() {
  if (!invoiceItems.length)      return showAlert('danger', 'Add at least one product.');
  const paymentData = Object.values(payments).filter(p => p.amount > 0);
  if (!paymentData.length)       return showAlert('danger', 'Enter at least one payment amount.');

  const btn = document.getElementById('saveInvoiceBtn');
  btn.querySelector('.btn-text').classList.add('d-none');
  btn.querySelector('.btn-loader').classList.remove('d-none');
  btn.disabled = true;

  try {
    const res  = await fetch('/sales', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        invoiceNo:   INVOICE_NO,
        warehouseId: document.getElementById('warehouseId').value || null,
        customerId:  document.getElementById('customerId').value  || null,
        saleDate:    document.getElementById('saleDate').value,
        notes:       document.getElementById('invoiceNotes').value,
        items:       invoiceItems.map(i => ({ productId: i.productId, quantity: i.qty, price: i.price, tax: i.tax, discount: i.discount||0 })),
        payments:    paymentData
      })
    });
    const data = await res.json();
    if (data.success) {
      showAlert('success', data.message);
      setTimeout(() => window.location.href = `/sales/${data.saleId}`, 1200);
    } else {
      showAlert('danger', data.message);
      btn.querySelector('.btn-text').classList.remove('d-none');
      btn.querySelector('.btn-loader').classList.add('d-none');
      btn.disabled = false;
    }
  } catch {
    showAlert('danger', 'Network error.');
    btn.querySelector('.btn-text').classList.remove('d-none');
    btn.querySelector('.btn-loader').classList.add('d-none');
    btn.disabled = false;
  }
}

function showAlert(type, msg) {
  const el = document.getElementById('invoiceAlert');
  el.className = `alert alert-${type}`;
  el.innerHTML = `<i class="bi bi-${type==='success'?'check-circle':'exclamation-triangle'}-fill me-2"></i>${msg}`;
  el.classList.remove('d-none');
  el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

document.addEventListener('click', e => {
  if (!e.target.closest('#productSearch') && !e.target.closest('#productDropdown'))
    document.getElementById('productDropdown').classList.add('d-none');
});
</script>
