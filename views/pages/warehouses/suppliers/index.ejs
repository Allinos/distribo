<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-truck me-2 text-success"></i>Suppliers</h2>
      <p class="page-subtitle">Manage suppliers and track purchase history</p>
    </div>
    <div class="page-actions">
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#supplierModal">
        <i class="bi bi-plus-lg me-2"></i>Add Supplier
      </button>
    </div>
  </div>

  <%- typeof flashMessages !== 'undefined' && flashMessages.success ? `<div class="alert alert-success mb-3">${flashMessages.success}</div>` : '' %>
  <%- typeof flashMessages !== 'undefined' && flashMessages.error   ? `<div class="alert alert-danger mb-3">${flashMessages.error}</div>` : '' %>

  <!-- Search -->
  <div class="card erp-card mb-4">
    <div class="card-body py-3">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-6">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" name="search" value="<%= search || '' %>" placeholder="Supplier name, phone or GSTIN...">
          </div>
        </div>
        <div class="col-md-6 d-flex gap-2">
          <button type="submit" class="btn btn-primary">Search</button>
          <a href="/suppliers" class="btn btn-outline-secondary">Reset</a>
        </div>
      </form>
    </div>
  </div>

  <!-- Table -->
  <div class="card erp-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover erp-table mb-0">
          <thead>
            <tr>
              <th>Supplier</th>
              <th>Phone</th>
              <th>GSTIN</th>
              <th class="text-center">Purchases</th>
              <th class="text-end">Total Purchased</th>
              <th class="text-end">Amount Paid</th>
              <th class="text-end">Balance Due</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!suppliers.length) { %>
            <tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-truck fs-2 d-block mb-2"></i>No suppliers found</td></tr>
            <% } %>
            <% suppliers.forEach(s => { %>
            <tr>
              <td>
                <div class="fw-medium"><%= s.name %></div>
                <small class="text-muted"><%= s.email || '' %></small>
              </td>
              <td class="text-muted"><%= s.phone || '—' %></td>
              <td><% if(s.gstin){ %><code class="small"><%= s.gstin %></code><% }else{ %>—<% } %></td>
              <td class="text-center">
                <span class="badge bg-light text-dark border"><%= s.purchaseCount || 0 %></span>
              </td>
              <td class="text-end fw-medium">₹<%= (s.totalPurchased||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></td>
              <td class="text-end text-success">₹<%= (s.amountPaid||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></td>
              <td class="text-end">
                <% if ((s.balanceDue||0) > 0.01) { %>
                  <span class="fw-bold text-danger">₹<%= parseFloat(s.balanceDue).toLocaleString('en-IN',{maximumFractionDigits:0}) %></span>
                <% } else { %>
                  <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Clear</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/suppliers/<%= s.id %>/ledger" class="btn btn-sm btn-outline-info me-1" title="Purchase History & Payments">
                  <i class="bi bi-journal-text"></i>
                </a>
                <button class="btn btn-sm btn-outline-primary me-1"
                  onclick='editSupplier(<%- JSON.stringify({id:s.id,name:s.name,phone:s.phone,email:s.email,gstin:s.gstin,address:s.address}) %>)'>
                  <i class="bi bi-pencil"></i>
                </button>
                <form action="/suppliers/<%= s.id %>?_method=DELETE" method="POST" class="d-inline"
                  onsubmit="return confirm('Delete <%= s.name %>?')">
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
    <div class="card-footer d-flex justify-content-between align-items-center">
      <small class="text-muted">Showing <%= (pagination.page-1)*pagination.limit+1 %>–<%= Math.min(pagination.page*pagination.limit,pagination.total) %> of <%= pagination.total %></small>
      <%- include('../../partials/pagination', { query: { search: search||'' } }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- Add/Edit Supplier Modal -->
<div class="modal fade" id="supplierModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form id="supplierForm" method="POST" action="/suppliers">
        <input type="hidden" name="_method" id="supplierMethod" value="POST">
        <div class="modal-header">
          <h5 class="modal-title" id="supplierModalTitle"><i class="bi bi-truck me-2 text-success"></i>Add Supplier</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label fw-medium">Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="name" id="suppName" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Phone</label>
              <input type="text" class="form-control" name="phone" id="suppPhone">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Email</label>
              <input type="email" class="form-control" name="email" id="suppEmail">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">GSTIN</label>
              <input type="text" class="form-control" name="gstin" id="suppGstin">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Address</label>
              <textarea class="form-control" name="address" id="suppAddress" rows="2"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-2"></i>Save Supplier</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function editSupplier(s) {
  document.getElementById('supplierModalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Edit Supplier';
  document.getElementById('supplierForm').action = `/suppliers/${s.id}`;
  document.getElementById('supplierMethod').value = 'PUT';
  document.getElementById('suppName').value    = s.name    || '';
  document.getElementById('suppPhone').value   = s.phone   || '';
  document.getElementById('suppEmail').value   = s.email   || '';
  document.getElementById('suppGstin').value   = s.gstin   || '';
  document.getElementById('suppAddress').value = s.address || '';
  new bootstrap.Modal(document.getElementById('supplierModal')).show();
}
document.getElementById('supplierModal').addEventListener('hidden.bs.modal', () => {
  document.getElementById('supplierForm').action = '/suppliers';
  document.getElementById('supplierMethod').value = 'POST';
  document.getElementById('supplierModalTitle').innerHTML = '<i class="bi bi-truck me-2 text-success"></i>Add Supplier';
  document.getElementById('supplierForm').reset();
});
</script>
