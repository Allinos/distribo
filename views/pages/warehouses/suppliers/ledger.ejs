<div class="page-content">
  <div class="page-header">
    <div>
      <h2 class="page-title"><i class="bi bi-truck me-2 text-success"></i><%= supplier.name %></h2>
      <p class="page-subtitle">
        <% if (supplier.phone) { %><i class="bi bi-telephone me-1"></i><%= supplier.phone %><% } %>
        <% if (supplier.email) { %> · <i class="bi bi-envelope me-1"></i><%= supplier.email %><% } %>
        <% if (supplier.gstin) { %> · GSTIN: <%= supplier.gstin %><% } %>
      </p>
    </div>
    <div class="page-actions">
      <a href="/suppliers" class="btn btn-outline-secondary me-2"><i class="bi bi-arrow-left me-2"></i>Back</a>
      <% if (summary.balanceDue > 0) { %>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#payModal">
        <i class="bi bi-cash me-2"></i>Record Payment
      </button>
      <% } %>
    </div>
  </div>

  <!-- Summary -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="stat-card stat-card-primary">
        <div class="stat-icon"><i class="bi bi-bag"></i></div>
        <div class="stat-content">
          <div class="stat-label">Total Purchased</div>
          <div class="stat-value">₹<%= summary.totalPurchased.toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
          <div class="stat-change neutral"><%= purchases.length %> orders</div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card stat-card-success">
        <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
        <div class="stat-content">
          <div class="stat-label">Amount Paid</div>
          <div class="stat-value">₹<%= summary.amountPaid.toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card <%= summary.balanceDue > 0 ? 'stat-card-danger' : 'stat-card-success' %>">
        <div class="stat-icon"><i class="bi bi-<%= summary.balanceDue > 0 ? 'exclamation-circle' : 'check-all' %>"></i></div>
        <div class="stat-content">
          <div class="stat-label">Balance Due (We Owe)</div>
          <div class="stat-value">₹<%= summary.balanceDue.toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
          <div class="stat-change <%= summary.balanceDue > 0 ? 'negative' : 'positive' %>"><%= summary.balanceDue > 0 ? 'Unpaid' : 'Settled' %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Date filter -->
  <div class="card erp-card mb-4">
    <div class="card-body py-3">
      <form method="GET" class="row g-3 align-items-end">
        <div class="col-md-3"><label class="form-label small fw-medium">From</label><input type="date" class="form-control" name="from" value="<%= from %>"></div>
        <div class="col-md-3"><label class="form-label small fw-medium">To</label><input type="date" class="form-control" name="to" value="<%= to %>"></div>
        <div class="col-md-4 d-flex gap-2 align-items-end">
          <button type="submit" class="btn btn-primary">Filter</button>
          <a href="/suppliers/<%= supplier.id %>/ledger" class="btn btn-outline-secondary">Reset</a>
        </div>
      </form>
    </div>
  </div>

  <div class="row g-4">
    <!-- Purchase History -->
    <div class="col-xl-8">
      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-bag me-2"></i>Purchase History</h5></div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover erp-table mb-0">
              <thead><tr><th>PO #</th><th>Date</th><th>Items</th><th>Warehouse</th><th class="text-end">Total</th><th>Status</th></tr></thead>
              <tbody>
                <% if (!purchases.length) { %>
                <tr><td colspan="6" class="text-center py-4 text-muted">No purchases found</td></tr>
                <% } %>
                <% purchases.forEach(p => { %>
                <tr>
                  <td><a href="/purchases/<%= p.id %>" class="fw-medium text-primary invoice-link"><%= p.poNo %></a></td>
                  <td class="text-muted small"><%= new Date(p.purchaseDate).toLocaleDateString('en-IN') %></td>
                  <td>
                    <% p.items.slice(0,2).forEach(i => { %>
                    <div class="small"><%= i.product.name %> × <%= i.quantity %></div>
                    <% }) %>
                    <% if (p.items.length > 2) { %><small class="text-muted">+<%= p.items.length-2 %> more</small><% } %>
                  </td>
                  <td class="text-muted small"><%= p.warehouse ? p.warehouse.name : '—' %></td>
                  <td class="text-end fw-medium">₹<%= parseFloat(p.total).toLocaleString('en-IN') %></td>
                  <td><span class="badge bg-<%= p.status==='RECEIVED'?'success':p.status==='CANCELLED'?'secondary':p.status==='ORDERED'?'info text-dark':'warning text-dark' %>"><%= p.status %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Ledger -->
    <div class="col-xl-4">
      <div class="card erp-card">
        <div class="card-header"><h5 class="card-title"><i class="bi bi-journal-text me-2"></i>Payment Ledger</h5></div>
        <div class="card-body p-0" style="max-height:400px;overflow-y:auto">
          <% if (!ledger.length) { %>
          <div class="text-center py-4 text-muted small">No ledger entries yet</div>
          <% } else { %>
          <% ledger.slice().reverse().forEach(e => { %>
          <div class="d-flex justify-content-between align-items-start px-3 py-2 border-bottom">
            <div>
              <div class="small fw-medium"><%= e.note || e.type %></div>
              <div class="text-muted" style="font-size:.7rem"><%= new Date(e.createdAt).toLocaleDateString('en-IN') %></div>
            </div>
            <div class="text-end ms-2">
              <div class="small fw-semibold <%= e.type==='PAYMENT'?'text-success':'text-danger' %>">
                <%= e.type==='PAYMENT'?'−':'+'%>₹<%= parseFloat(e.amount).toLocaleString('en-IN',{maximumFractionDigits:0}) %>
              </div>
              <div class="text-muted" style="font-size:.68rem">Bal: ₹<%= parseFloat(e.balance).toLocaleString('en-IN',{maximumFractionDigits:0}) %></div>
            </div>
          </div>
          <% }) %>
          <% } %>
        </div>
        <% if (summary.balanceDue > 0) { %>
        <div class="card-footer" style="background:rgba(220,38,38,.07)">
          <div class="d-flex justify-content-between align-items-center">
            <span class="fw-semibold text-danger small">We owe supplier</span>
            <span class="fw-bold text-danger">₹<%= summary.balanceDue.toLocaleString('en-IN',{maximumFractionDigits:0}) %></span>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="payModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">Record Payment to Supplier</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <div id="payMsg" class="d-none mb-2"></div>
        <div class="mb-3">
          <label class="form-label small fw-medium">Amount (₹)</label>
          <input type="number" class="form-control" id="payAmt" min="0.01" step="0.01"
            value="<%= summary.balanceDue.toFixed(2) %>">
        </div>
        <div class="mb-3">
          <label class="form-label small fw-medium">Mode</label>
          <select class="form-select" id="payMode">
            <option value="BANK_TRANSFER">🏦 Bank Transfer</option>
            <option value="CASH">💵 Cash</option>
            <option value="UPI">📱 UPI</option>
            <option value="CARD">💳 Card</option>
          </select>
        </div>
        <div>
          <label class="form-label small fw-medium">Reference</label>
          <input type="text" class="form-control" id="payRef" placeholder="Txn ID, cheque #...">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="submitPayment()">Record</button>
      </div>
    </div>
  </div>
</div>
<script>
async function submitPayment() {
  const amount = document.getElementById('payAmt').value;
  const mode   = document.getElementById('payMode').value;
  const ref    = document.getElementById('payRef').value;
  if (!amount) { showMsg('danger','Enter amount.'); return; }
  const res  = await fetch(`/suppliers/<%= supplier.id %>/payment`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ amount, mode, reference: ref })
  });
  const data = await res.json();
  showMsg(data.success?'success':'danger', data.message);
  if (data.success) setTimeout(()=>location.reload(),1200);
}
function showMsg(t,m){ const el=document.getElementById('payMsg'); el.className=`alert alert-${t} py-2 small`; el.textContent=m; el.classList.remove('d-none'); }
</script>
