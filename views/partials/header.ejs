<header class="app-header">
  <div class="header-left">
    <button class="btn sidebar-toggle" id="sidebarToggle">
      <i class="bi bi-list"></i>
    </button>
    <nav aria-label="breadcrumb" class="d-none d-md-block">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active"><%= title %></li>
      </ol>
    </nav>
  </div>

  <div class="header-right">
    <div class="header-date d-none d-lg-flex">
      <i class="bi bi-calendar3 me-2"></i>
      <span id="currentDate"></span>
    </div>

    <div class="dropdown">
      <button class="btn header-user-btn dropdown-toggle" data-bs-toggle="dropdown">
        <div class="header-avatar">
          <%= user ? user.name.charAt(0).toUpperCase() : 'U' %>
        </div>
        <span class="d-none d-md-inline ms-2"><%= user ? user.name : 'User' %></span>
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow">
        <li>
          <div class="dropdown-header">
            <div class="fw-semibold"><%= user ? user.name : '' %></div>
            <small class="text-muted"><%= user ? user.email : '' %></small>
          </div>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item" href="/auth/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
        <li><a class="dropdown-item" href="/settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
      </ul>
    </div>
  </div>
</header>
