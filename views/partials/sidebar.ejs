<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
    <span class="brand-name">
      <%= appName %>
    </span>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">MAIN</div>
    <ul class="nav flex-column">
      <li class="nav-item">
        <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">
          <i class="bi bi-speedometer2"></i><span>Dashboard</span>
        </a>
      </li>
    </ul>

    <div class="nav-section">
      <a class="nav-link d-flex align-items-center justify-content-between py-2 px-3 text-uppercase fw-bold small text-muted"
        id="inventoryToggle" data-bs-toggle="collapse" href="#inventoryCollapse" role="button" data-category="inventory"
        aria-expanded="<%= ['/warehouses', '/products', '/categories', '/customers', '/suppliers', '/batches'].some(path => currentPath.startsWith(path)) ? 'true' : 'false' %>"
        aria-controls="inventoryCollapse" style="letter-spacing: 0.05rem; text-decoration: none;color: white!important">
        <span>
          <i class="bi bi-box-fill me-2"></i>INVENTORY
        </span>
        <i class="bi bi-chevron-down collapse-icon small" style="color: white;"></i>
      </a>

      <div
        class="collapse <%= ['/warehouses', '/products', '/categories', '/customers', '/suppliers', '/batches'].some(path => currentPath.startsWith(path)) ? 'show' : '' %>"
        id="inventoryCollapse">
        <ul class="nav flex-column ms-2">
          <li><a href="/warehouses" class="nav-link <%= currentPath.startsWith('/warehouses') ? 'active' : '' %>"><i
                class="bi bi-building"></i><span>Warehouses</span></a></li>
          <li><a href="/products" class="nav-link <%= currentPath.startsWith('/products') ? 'active' : '' %>"><i
                class="bi bi-box-seam"></i><span>Products</span></a></li>
          <li><a href="/categories" class="nav-link <%= currentPath.startsWith('/categories') ? 'active' : '' %>"><i
                class="bi bi-tags"></i><span>Categories</span></a></li>
          <li><a href="/customers" class="nav-link <%= currentPath.startsWith('/customers') ? 'active' : '' %>"><i
                class="bi bi-people"></i><span>Customers</span></a></li>
          <li><a href="/suppliers" class="nav-link <%= currentPath.startsWith('/suppliers') ? 'active' : '' %>"><i
                class="bi bi-truck"></i><span>Suppliers</span></a></li>
          <li><a href="/batches" class="nav-link <%= currentPath.startsWith('/batches') ? 'active' : '' %>"><i
                class="bi bi-layers"></i><span>Batches & Expiry</span></a></li>
        </ul>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const inventoryCollapse = document.getElementById('inventoryCollapse');
        const storageKey = "nav_state_inventory";

        // 1. Restore state on load
        const savedState = localStorage.getItem(storageKey);

        // Only override if there's a saved preference and it's NOT currently active 
        // (We prioritize 'show' if a child page is currently active)
        if (savedState === 'shown' && !inventoryCollapse.classList.contains('show')) {
          const bsCollapse = new bootstrap.Collapse(inventoryCollapse, { show: true });
        } else if (savedState === 'hidden' && inventoryCollapse.classList.contains('show')) {
          // Only hide if the current path is NOT one of the inventory sub-pages
          const isSubPageActive = <%=['/warehouses', '/products', '/categories', '/customers', '/suppliers', '/batches'].some(path => currentPath.startsWith(path)) %>;
          if (!isSubPageActive) {
            const bsCollapse = new bootstrap.Collapse(inventoryCollapse, { hide: true });
          }
        }

        // 2. Listen for toggles to save state
        inventoryCollapse.addEventListener('shown.bs.collapse', function () {
          localStorage.setItem(storageKey, 'shown');
        });

        inventoryCollapse.addEventListener('hidden.bs.collapse', function () {
          localStorage.setItem(storageKey, 'hidden');
        });
      });
    </script>

    <style>
      [aria-expanded="true"] .collapse-icon {
        transform: rotate(180deg);
      }

      .collapse-icon {
        transition: transform 0.3s ease;
      }

      #inventoryCollapse .nav-link {
        padding-left: 1.5rem;
        font-size: 0.9rem;
        opacity: 0.85;
      }

      #inventoryCollapse .nav-link.active {
        opacity: 1;
        font-weight: 500;
      }
    </style>

    <div class="nav-section-label">TRANSACTIONS</div>
    <ul class="nav flex-column">
      <li><a href="/sales" class="nav-link <%= currentPath.startsWith('/sales') ? 'active' : '' %>"><i
            class="bi bi-receipt"></i><span>Sales</span></a></li>
      <li><a href="/purchases" class="nav-link <%= currentPath.startsWith('/purchases') ? 'active' : '' %>"><i
            class="bi bi-cart-check"></i><span>Purchases</span></a></li>
      <li><a href="/expenses" class="nav-link <%= currentPath.startsWith('/expenses') ? 'active' : '' %>"><i
            class="bi bi-wallet2"></i><span>Expenses</span></a></li>
      <li><a href="/returns" class="nav-link <%= currentPath.startsWith('/returns') ? 'active' : '' %>"><i
            class="bi bi-arrow-return-left"></i><span>Returns</span></a></li>
      <li><a href="/writeoffs" class="nav-link <%= currentPath.startsWith('/writeoffs') ? 'active' : '' %>"><i
            class="bi bi-trash"></i><span>Write-offs</span></a></li>
    </ul>

    <div class="nav-section-label">FLEET</div>
    <ul class="nav flex-column">
      <li><a href="/vehicles"
          class="nav-link <%= currentPath === '/vehicles' || currentPath.startsWith('/vehicles/') && !currentPath.startsWith('/vehicles/sales') ? 'active' : '' %>"><i
            class="bi bi-truck-front"></i><span>Vehicles & Stock</span></a></li>
      <li><a href="/vehicles/sales" class="nav-link <%= currentPath.startsWith('/vehicles/sales') ? 'active' : '' %>"><i
            class="bi bi-bag-check"></i><span>Van Sales</span></a></li>
    </ul>

    <% if (user && (user.role==='ADMIN' || user.role==='MANAGER' )) { %>
      <div class="nav-section-label">ADMIN</div>
      <ul class="nav flex-column">
        <% if (user.role==='ADMIN' ) { %>
          <li><a href="/users" class="nav-link <%= currentPath.startsWith('/users') ? 'active' : '' %>"><i
                class="bi bi-person-badge"></i><span>Users</span></a></li>
          <li><a href="/settings" class="nav-link <%= currentPath.startsWith('/settings') ? 'active' : '' %>"><i
                class="bi bi-gear"></i><span>Settings</span></a></li>
          <% } %>
            <!-- <li><a href="/backup" class="nav-link <%= currentPath.startsWith('/backup') ? 'active' : '' %>"><i class="bi bi-cloud-arrow-up"></i><span>Backup</span></a></li> -->
      </ul>
      <% } %>
  </nav>

  <div class="sidebar-footer">
    <div class="user-info">
      <div class="user-avatar">
        <%= user ? user.name.charAt(0).toUpperCase() : 'U' %>
      </div>
      <div class="user-details">
        <div class="user-name">
          <%= user ? user.name : 'User' %>
        </div>
        <div class="user-role">
          <%= user ? user.role : '' %>
        </div>
      </div>
      <a href="/auth/logout" class="ms-auto text-muted" title="Logout" style="text-decoration:none">
        <i class="bi bi-box-arrow-right"></i>
      </a>
    </div>
  </div>
</aside>